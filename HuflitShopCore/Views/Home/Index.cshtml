@model IEnumerable<HuflitShopCore.DTOs.ProductListDTO>
@{
    ViewData["Title"] = "Huflit Shop - Thời trang nữ thiết kế cao cấp";
}

<h1 class="d-none">Huflit Shop - Thời trang nữ thiết kế cao cấp</h1>

@* ── SECTION 1: HERO BANNER ── *@
<section class="hs-hero">
    <div class="hs-hero__slide" style="background-image: url('/Client/img/fashion-3.jpg');">
        <div class="hs-hero__overlay"></div>
        <div class="hs-hero__content">
            <p class="hs-hero__sub">Bộ sưu tập 2025</p>
            <h2 class="hs-hero__title">KIẾN TẠO<br>PHONG CÁCH</h2>
            <p class="hs-hero__desc">Tôn vinh nét quyến rũ tự nhiên, thanh lịch qua từng thiết kế nữ cao cấp độc quyền của chúng tôi.</p>
            <a asp-controller="Product" asp-action="Product" class="hs-btn hs-btn--white">Khám phá ngay</a>
        </div>
    </div>
</section>

@* ── SECTION 2: 4-COLUMN CATEGORY BANNERS ── *@
<section class="hs-cats">
    <div class="container-fluid px-0">
        <div class="row no-gutters">
            <div class="col-6 col-md-3">
                <a asp-controller="Product" asp-action="Product" class="hs-cat-card">
                    <img src="/Client/img/signup-1.jpg" alt="Váy Đầm" loading="lazy">
                    <div class="hs-cat-card__label">Váy Đầm</div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Product" asp-action="Product" class="hs-cat-card">
                    <img src="/Client/img/signup-2.jpg" alt="Set Trang Phục" loading="lazy">
                    <div class="hs-cat-card__label">Set Trang Phục</div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Product" asp-action="Product" class="hs-cat-card">
                    <img src="/Client/img/signup-3.jpg" alt="Thời Trang Công Sở" loading="lazy">
                    <div class="hs-cat-card__label">Thời Trang Công Sở</div>
                </a>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Product" asp-action="Product" class="hs-cat-card">
                    <img src="/Client/img/signup-4.jpg" alt="Thời Trang Dạo Phố" loading="lazy">
                    <div class="hs-cat-card__label">Thời Trang Dạo Phố</div>
                </a>
            </div>
        </div>
    </div>
</section>

@* ── SECTION 3: PRODUCT GRID ── *@
<section class="hs-products">
    <div class="container">
        <div class="hs-section-head">
            <h2 class="hs-section-head__title">Sản Phẩm Mới Nhất</h2>
            <div class="hs-section-head__line"></div>
            <p class="hs-section-head__desc">Cập nhật liên tục các thiết kế thời trang nữ mới nhất, phong cách nhất</p>
        </div>

        <div class="row">
            @if (Model != null)
            {
                foreach (var pro in Model)
                {
                    <div class="col-xl-3 col-lg-3 col-md-4 col-6 mb-4">
                        <div class="hs-product-card">
                            <div class="hs-product-card__thumb">
                                <a asp-controller="Product" asp-action="Details" asp-route-id="@pro.Id">
                                    <img src="@HuflitShopCore.Helpers.ImageRouteHelper.Resolve(pro.ImageDefault)" alt="@pro.Name" loading="lazy">
                                </a>
                                @if (pro.Count <= 0)
                                {
                                    <span class="hs-product-card__badge hs-product-card__badge--sold">Hết hàng</span>
                                }
                                else
                                {
                                    <span class="hs-product-card__badge">Mới</span>
                                }
                                <div class="hs-product-card__actions">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@pro.Id" class="hs-product-card__action-btn hs-product-card__action-btn--outline">
                                        <i class="fas fa-eye"></i> Xem
                                    </a>
                                    @if (pro.Count > 0)
                                    {
                                        <a asp-controller="Product" asp-action="BuyNow" asp-route-id="@pro.Id" class="hs-product-card__action-btn hs-product-card__action-btn--solid">
                                            <i class="fas fa-shopping-bag"></i> Mua ngay
                                        </a>
                                    }
                                </div>
                            </div>
                            <div class="hs-product-card__body">
                                <h3 class="hs-product-card__name">
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@pro.Id">@pro.Name</a>
                                </h3>
                                <div class="hs-product-card__price">@pro.Price.ToString("N0")₫</div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <p class="text-muted">Không có sản phẩm nào để hiển thị.</p>
                </div>
            }
        </div>

        <div class="text-center mt-2 mb-4">
            <a asp-controller="Product" asp-action="Product" class="hs-btn hs-btn--outline">Xem tất cả sản phẩm</a>
        </div>
    </div>
</section>

@* ── SECTION 4: PROMO STRIP (Navy background) ── *@
<section class="hs-promo-strip">
    <div class="container">
        <div class="hs-promo-strip__inner">
            <div class="hs-promo-strip__item">
                <i class="fas fa-medal"></i>
                <div>
                    <strong>Thiết Kế Độc Quyền</strong>
                    <span>Phong cách dẫn đầu xu hướng</span>
                </div>
            </div>
            <div class="hs-promo-strip__item">
                <i class="fas fa-gem"></i>
                <div>
                    <strong>Chất Liệu Cao Cấp</strong>
                    <span>Vải tuyển chọn, thấm hút tốt</span>
                </div>
            </div>
            <div class="hs-promo-strip__item">
                <i class="fas fa-shipping-fast"></i>
                <div>
                    <strong>Giao Hàng Toàn Quốc</strong>
                    <span>Nhanh chóng, an toàn, tiện lợi</span>
                </div>
            </div>
            <div class="hs-promo-strip__item">
                <i class="fas fa-undo-alt"></i>
                <div>
                    <strong>Đổi Trả Linh Hoạt</strong>
                    <span>7 ngày đổi trả miễn phí</span>
                </div>
            </div>
        </div>
    </div>
</section>

@* ── SECTION 5: ABOUT US ── *@
<section class="hs-about">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <div class="hs-about__img-grid">
                    <div class="hs-about__img-main">
                        <img src="/Client/img/fashion-2.jpg" alt="Huflit Shop Studio">
                    </div>
                    <div class="hs-about__img-accent">
                        <img src="/Client/img/sanpham-1.jpg" alt="Huflit Shop Fashion">
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hs-about__content">
                    <p class="hs-about__sub">Chúng tôi là ai?</p>
                    <h2 class="hs-about__title">Về Huflit Shop</h2>
                    <div class="hs-about__divider"></div>
                    <p class="hs-about__desc">
                        Huflit Shop chuyên thiết kế và cung cấp thời trang nữ cao cấp với phong cách tinh tế, thanh lịch và luôn dẫn đầu xu hướng. Chúng tôi cam kết sử dụng chất liệu vải tuyển chọn tốt nhất kết hợp cùng những đường may tỉ mỉ, mang lại sự tự tin và tỏa sáng.
                    </p>
                    <ul class="hs-about__list">
                        <li><i class="fas fa-check-circle"></i> Thiết kế độc quyền, cập nhật xu hướng liên tục</li>
                        <li><i class="fas fa-check-circle"></i> Chất liệu vải thân thiện da, thoáng mát, giữ form</li>
                        <li><i class="fas fa-check-circle"></i> Tư vấn size tận tâm, hỗ trợ 24/7</li>
                        <li><i class="fas fa-check-circle"></i> Đổi trả linh hoạt, giao hàng nhanh toàn quốc</li>
                    </ul>
                    <a asp-controller="About" asp-action="About" class="hs-btn hs-btn--primary">Tìm hiểu thêm</a>
                </div>
            </div>
        </div>
    </div>
</section>

@* ── SECTION 6: LOOKBOOK (Split full-width panels) ── *@
<section class="hs-lookbook">
    <div class="row no-gutters">
        <div class="col-md-6">
            <a asp-controller="Product" asp-action="Product" class="hs-lookbook__panel" style="background-image: url('/Client/img/fashion-1.jpg');">
                <div class="hs-lookbook__overlay"></div>
                <div class="hs-lookbook__text">
                    <span>Váy Đầm &amp; Đầm Thiết Kế</span>
                    <strong>Khám phá ngay &rarr;</strong>
                </div>
            </a>
        </div>
        <div class="col-md-6">
            <a asp-controller="Product" asp-action="Product" class="hs-lookbook__panel" style="background-image: url('/Client/img/signup-2.jpg');">
                <div class="hs-lookbook__overlay"></div>
                <div class="hs-lookbook__text">
                    <span>Set Đồ &amp; Trang Phục Công Sở</span>
                    <strong>Khám phá ngay &rarr;</strong>
                </div>
            </a>
        </div>
    </div>
</section>

@* ── SECTION 7: TESTIMONIALS ── *@
<section class="hs-testimonials py-5 bg-light">
    <div class="container">
        <div class="hs-section-head text-center mb-5">
            <h2 class="hs-section-head__title font-weight-bold">Khách Hàng Nói Gì</h2>
            <div class="hs-section-head__line mx-auto mt-2" style="width: 60px; height: 3px; background-color: var(--mainColor, #2563eb);"></div>
        </div>
        <div class="swiper-container hs-review-swiper pb-5">
            <div class="swiper-wrapper">

                <!-- Slide 1 -->
                <div class="swiper-slide">
                    <div class="hs-review-card bg-white p-4 rounded shadow-sm h-100 d-flex flex-column">
                        <div class="hs-review-card__stars text-warning mb-3" style="font-size: 1.25rem;">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                        <p class="hs-review-card__text font-italic text-muted flex-grow-1" style="line-height: 1.6;">"Đồ của Huflit Shop thiết kế rất sang trọng và tôn dáng. Vải mặc rất thoải mái, mịn mát da. Tôi đã mua 3 lần và lần nào cũng cực kỳ ưng ý!"</p>
                        <div class="hs-review-card__author d-flex align-items-center mt-4 pt-3 border-top">
                            <div class="mr-3 rounded-circle shadow-sm" style="width: 60px; height: 60px; min-width: 60px; overflow: hidden; flex-shrink: 0; border: 2px solid #fff;">
                                <img src="/Client/img/default-user.jpg" alt="Nguyễn Thảo" style="width: 100%; height: 100%; object-fit: cover; display: block;">
                            </div>
                            <div>
                                <strong class="d-block text-dark" style="font-size: 1.05rem;">Nguyễn Thảo</strong>
                                <span class="text-secondary small">Hà Nội · Nhân viên văn phòng</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Slide 2 -->
                <div class="swiper-slide">
                    <div class="hs-review-card bg-white p-4 rounded shadow-sm h-100 d-flex flex-column">
                        <div class="hs-review-card__stars text-warning mb-3" style="font-size: 1.25rem;">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                        <p class="hs-review-card__text font-italic text-muted flex-grow-1" style="line-height: 1.6;">"Tôi rất thích form đầm dự tiệc ở đây. Nhân viên tư vấn nhiệt tình, ship hàng nhanh và được kiểm tra hàng thoải mái trước khi nhận."</p>
                        <div class="hs-review-card__author d-flex align-items-center mt-4 pt-3 border-top">
                            <div class="mr-3 rounded-circle shadow-sm" style="width: 60px; height: 60px; min-width: 60px; overflow: hidden; flex-shrink: 0; border: 2px solid #fff;">
                                <img src="/Client/img/default-user.jpg" alt="Lê Giang" style="width: 100%; height: 100%; object-fit: cover; display: block;">
                            </div>
                            <div>
                                <strong class="d-block text-dark" style="font-size: 1.05rem;">Lê Giang</strong>
                                <span class="text-secondary small">TP.HCM · Kinh doanh tự do</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Slide 3 -->
                <div class="swiper-slide">
                    <div class="hs-review-card bg-white p-4 rounded shadow-sm h-100 d-flex flex-column">
                        <div class="hs-review-card__stars text-warning mb-3" style="font-size: 1.25rem;">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                        <p class="hs-review-card__text font-italic text-muted flex-grow-1" style="line-height: 1.6;">"Mua áo blazer công sở tặng bạn gái. Chất vải dày dặn, đường may sắc sảo, được tặng thêm hộp thiệp xinh xắn. Rất đáng tiền!"</p>
                        <div class="hs-review-card__author d-flex align-items-center mt-4 pt-3 border-top">
                            <div class="mr-3 rounded-circle shadow-sm" style="width: 60px; height: 60px; min-width: 60px; overflow: hidden; flex-shrink: 0; border: 2px solid #fff;">
                                <img src="/Client/img/default-user.jpg" alt="Trần Minh" style="width: 100%; height: 100%; object-fit: cover; display: block;">
                            </div>
                            <div>
                                <strong class="d-block text-dark" style="font-size: 1.05rem;">Trần Minh</strong>
                                <span class="text-secondary small">Đà Nẵng · Kỹ sư phần mềm</span>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
            <div class="swiper-pagination hs-review-swiper__pagination position-relative mt-4"></div>
        </div>
    </div>
</section>

@* ── SECTION 8: PAYMENT METHODS ── *@
<section class="hs-payments">
    <div class="container">
        <div class="hs-payments__inner">
            <span class="hs-payments__label">Chấp nhận thanh toán:</span>
            <div class="hs-payments__logos">
                <img src="https://bizweb.dktcdn.net/100/601/974/themes/1047016/assets/img_brand_1.jpg?1776407985038" alt="Visa">
                <img src="https://bizweb.dktcdn.net/100/601/974/themes/1047016/assets/img_brand_2.jpg?1776407985038" alt="Mastercard">
                <img src="https://bizweb.dktcdn.net/100/601/974/themes/1047016/assets/img_brand_3.jpg?1776407985038" alt="JCB">
                <img src="https://bizweb.dktcdn.net/100/601/974/themes/1047016/assets/img_brand_4.jpg?1776407985038" alt="Momo">
                <img src="https://bizweb.dktcdn.net/100/601/974/themes/1047016/assets/img_brand_5.jpg?1776407985038" alt="ZaloPay">
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function () {
            new Swiper('.hs-review-swiper', {
                slidesPerView: 1,
                spaceBetween: 24,
                grabCursor: true,
                loop: true,
                autoplay: { delay: 5000, disableOnInteraction: false },
                pagination: { el: '.hs-review-swiper__pagination', clickable: true },
                breakpoints: {
                    768: { slidesPerView: 2 },
                    1024: { slidesPerView: 3 }
                }
            });
        });
    </script>
}
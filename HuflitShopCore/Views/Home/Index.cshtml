@model IEnumerable<HuflitShopCore.DTOs.ProductListDTO>
@{
    ViewData["Title"] = "Huflit Shop - Thời trang nữ thiết kế cao cấp";
}

<h1 class="d-none">Huflit Shop - Thời trang nữ thiết kế cao cấp</h1>

<!-- 1. Slider Section -->
<div class="section_slider">
    <div class="swiper-container">
        <div class="swiper-wrapper">
            <div class="swiper-slide">
                <img src="~/Bean/slider_1.jpg" alt="Huflit Shop Slider">
                <div class="thumb-slider-text">
                    <div class="slider-text">
                        <h2 class="title">KIẾN TẠO PHONG CÁCH</h2>
                        <div class="content">Cùng <span>Huflit Shop</span></div>
                        <div class="content_2">
                            Tôn vinh nét quyến rũ tự nhiên, thanh lịch và hiện đại qua từng bộ sưu tập thời trang nữ thiết kế cao cấp của chúng tôi.
                        </div>
                        <a asp-controller="Product" asp-action="Product" class="theme-btn btn-style-two">Mua Sắm Ngay</a>
                    </div>
                </div>
            </div>
        </div>
        <!-- Add Pagination & Nav Buttons if multiple slides -->
        <div class="swiper-button-prev"></div>
        <div class="swiper-button-next"></div>
        <div class="swiper-pagination"></div>
    </div>
</div>

<!-- 2. About Section -->
<section class="section_about">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <div class="img-box10">
                    <div class="img1">
                        <img src="~/Bean/section_about_product_2.jpg" alt="Huflit Shop Studio" class="img-fluid">
                    </div>
                    <div class="img2">
                        <img src="~/Bean/section_about_product_1.jpg" alt="Huflit Shop Fashion" class="img-fluid">
                    </div>
                    <div class="img3">
                        <img src="~/Client/img/set-1.jpg" alt="Huflit Shop Model" class="img-fluid">
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="product-content pl-lg-4">
                    <div class="section-title-about">
                        <div class="sub_title">Chúng tôi là ai?</div>
                        <h2>Về Huflit Shop</h2>
                    </div>
                    <div class="desc">
                        Huflit Shop chuyên thiết kế và cung cấp thời trang nữ cao cấp với phong cách tinh tế, thanh lịch và luôn dẫn đầu xu hướng. Chúng tôi cam kết sử dụng chất liệu vải tuyển chọn tốt nhất kết hợp cùng những đường may tỉ mỉ của những thợ lành nghề, mang lại cho phái đẹp sự tự tin, tỏa sáng.
                    </div>
                    <ul class="box_thong_so">
                        <li>
                            <h3>Thiết kế độc quyền và luôn cập nhật xu hướng mới nhất.</h3>
                        </li>
                        <li>
                            <h3>Chất liệu vải thân thiện với làn da, thoáng mát và giữ form.</h3>
                        </li>
                        <li>
                            <h3>Dịch vụ tư vấn tận tâm giúp bạn chọn size vừa vặn nhất.</h3>
                        </li>
                        <li>
                            <h3>Đổi trả hàng linh hoạt và giao hàng nhanh chóng toàn quốc.</h3>
                        </li>
                    </ul>
                    <div class="box-contact">
                        <a asp-controller="About" asp-action="About" class="theme-btn btn-style-three">Xem chi tiết</a>
                        <div class="btn_contact-phone">
                            <a class="icon_phone" href="tel:+84947653170">
                                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" width="20px" height="20px">
                                    <path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 0 0-1.01.24l-1.57 1.97c-2.83-1.35-5.48-3.9-6.89-6.83l1.95-1.66c.27-.28.35-.67.24-1.02-.37-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 1 3 1.24 3 1.99 3 11.38 10.62 19 20 19c.73 0 .99-.51.99-.99v-1.63c0-.55-.45-.99-.98-.99z"/>
                                </svg>
                            </a>
                            <div class="box-contact-phone-info">
                                <span>Gọi điện tư vấn!</span>
                                <a href="tel:+84947653170">0947 653 170</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 3. Dynamic Products Section -->
<section class="section_product_tab">
    <div class="container">
        <div class="section-title-tab">
            <h2><a asp-controller="Product" asp-action="Product">Sản Phẩm Mới Nhất</a></h2>
            <div class="desc">
                Cập nhật các thiết kế thời trang nữ mới nhất của shop. Hãy chọn cho mình bộ cánh ưng ý để khẳng định phong cách bản thân ngay hôm nay!
            </div>
        </div>
        <div class="row">
            @if (Model != null)
            {
                foreach (var pro in Model)
                {
                    <div class="col-xl-3 col-lg-3 col-md-4 col-6 mb-4">
                        <div class="item_product_main">
                            <form asp-action="AddCart" asp-controller="Product" method="post" class="variants product-action item-product-main duration-300">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@pro.Id" />
                                <div class="product-thumbnail">
                                    <a class="image_thumb" asp-controller="Product" asp-action="Details" asp-route-id="@pro.Id">
                                        @if (string.IsNullOrEmpty(pro.ImageDefault) || pro.ImageDefault.Contains("Tên_Cloud_Của_Bạn"))
                                        {
                                            <img src="~/Client/img/default-product.jpg" alt="@pro.Name">
                                        }
                                        else
                                        {
                                            <img src="@pro.ImageDefault" alt="@pro.Name">
                                        }
                                    </a>
                                    <div class="badge">Hot</div>
                                    <a asp-controller="Product" asp-action="Details" asp-route-id="@pro.Id" class="btn-views" title="Xem chi tiết">
                                        <i class="fas fa-eye text-primary"></i>
                                    </a>
                                </div>
                                <div class="product-info">
                                    <h3 class="product-name">
                                        <a asp-controller="Product" asp-action="Details" asp-route-id="@pro.Id">@pro.Name</a>
                                    </h3>
                                    <div class="product-price-cart">
                                        <span class="price">@pro.Price.ToString("N0")₫</span>
                                    </div>
                                    <div class="product-button">
                                        @if (pro.Count > 0)
                                        {
                                            <button class="btn-cart" type="submit">Thêm vào giỏ</button>
                                        }
                                        else
                                        {
                                            <button class="btn-cart" type="button" disabled style="background-color: #cbd5e1 !important; color: #64748b !important; cursor: not-allowed;">Hết hàng</button>
                                        }
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</section>

<!-- 4. Collections Section -->
<section class="section_project">
    <div class="container">
        <div class="section-title-project text-center mb-5">
            <div class="sub_title">Bộ sưu tập thu hút</div>
            <h2>Xu Hướng Thời Trang Nữ</h2>
        </div>
        <div class="row">
            <div class="col-md-4 col-12 mb-4">
                <div class="item_project">
                    <a class="image-blog" asp-controller="Product" asp-action="Product">
                        <img src="~/Client/img/set-1.jpg" alt="Váy Đầm Thiết Kế" class="img-fluid w-100" style="height: 250px; object-fit: cover;">
                    </a>
                    <div class="blog_content">
                        <h3><a asp-controller="Product" asp-action="Product">Váy Đầm Thiết Kế</a></h3>
                        <p>Những thiết kế váy đầm xòe, ôm dáng cực kỳ quyến rũ, tôn vinh vóc dáng yêu kiều của bạn.</p>
                        <a asp-controller="Product" asp-action="Product" class="theme-btn btn-style-three mt-3 w-100 justify-content-center py-2" style="font-size:0.9rem;">Khám phá ngay</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-12 mb-4">
                <div class="item_project">
                    <a class="image-blog" asp-controller="Product" asp-action="Product">
                        <img src="~/Client/img/set-2.jpg" alt="Set Đồ Năng Động" class="img-fluid w-100" style="height: 250px; object-fit: cover;">
                    </a>
                    <div class="blog_content">
                        <h3><a asp-controller="Product" asp-action="Product">Set Đồ Năng Động</a></h3>
                        <p>Sự kết hợp thoải mái giữa áo thun, chân váy và vest giúp bạn năng động suốt ngày dài.</p>
                        <a asp-controller="Product" asp-action="Product" class="theme-btn btn-style-three mt-3 w-100 justify-content-center py-2" style="font-size:0.9rem;">Khám phá ngay</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4 col-12 mb-4">
                <div class="item_project">
                    <a class="image-blog" asp-controller="Product" asp-action="Product">
                        <img src="~/Client/img/set-3.jpg" alt="Thời Trang Công Sở" class="img-fluid w-100" style="height: 250px; object-fit: cover;">
                    </a>
                    <div class="blog_content">
                        <h3><a asp-controller="Product" asp-action="Product">Thời Trang Công Sở</a></h3>
                        <p>Lịch lãm, trang nhã nhưng vẫn giữ được nét nữ tính cuốn hút với áo sơ mi lụa và blazer.</p>
                        <a asp-controller="Product" asp-action="Product" class="theme-btn btn-style-three mt-3 w-100 justify-content-center py-2" style="font-size:0.9rem;">Khám phá ngay</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 5. Why Choose Us Section -->
<section class="section_choose">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <div class="box_img_choose">
                    <img src="~/Client/img/signup-1.jpg" alt="Fashion Design Studio">
                </div>
            </div>
            <div class="col-lg-6">
                <div class="section-title-choose pl-lg-4">
                    <div class="sub_title">Tại sao chọn Huflit Shop</div>
                    <h2>Định Hình Phong Cách Riêng Cho Bạn</h2>
                    <div class="desc">
                        Mỗi thiết kế từ Huflit Shop đều được tạo dựng với khát vọng tôn lên vẻ tự tin và quý phái của mỗi cô gái, giúp nàng luôn là tâm điểm trong mọi cuộc gặp gỡ.
                    </div>
                    <ul class="why-feature-list">
                        <li class="why-feature-list-wrap">
                            <div class="why-feature-list-details">
                                <h3 class="feature-title"><span class="number">01</span> Thiết kế độc quyền</h3>
                                <p class="feature-text">Đội ngũ stylist thiết kế độc quyền, dẫn đầu xu hướng thời trang công sở và dạo phố cao cấp.</p>
                            </div>
                        </li>
                        <li class="why-feature-list-wrap">
                            <div class="why-feature-list-details">
                                <h3 class="feature-title"><span class="number">02</span> Chất liệu chọn lọc</h3>
                                <p class="feature-text">Cam kết 100% sử dụng vải cao cấp mát mịn, thấm hút tốt, không phai màu hay sờn chỉ.</p>
                            </div>
                        </li>
                        <li class="why-feature-list-wrap">
                            <div class="why-feature-list-details">
                                <h3 class="feature-title"><span class="number">03</span> May đo chuẩn xác</h3>
                                <p class="feature-text">Sản phẩm được gia công kỹ lưỡng từng đường kim mũi chỉ, chuẩn form tôn dáng chuẩn xác nhất.</p>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 6. Testimonials Section -->
<section class="section_feedback">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-5 mb-5 mb-lg-0">
                <div class="banner_feedback">
                    <img src="~/Client/img/signup-2.jpg" alt="Customer Banner">
                </div>
            </div>
            <div class="col-lg-7 pl-lg-5">
                <div class="section-title-feedback">
                    <div class="sub_title">Phản hồi từ khách hàng</div>
                    <h2>Khách Hàng Nói Gì Về Chúng Tôi?</h2>
                </div>
                <div class="swiper-container swiper_feedback">
                    <div class="swiper-wrapper">
                        <div class="swiper-slide">
                            <div class="feedback-item">
                                <span class="star-rating"></span>
                                <div class="block-content">

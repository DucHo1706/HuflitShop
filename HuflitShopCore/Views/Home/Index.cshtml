                                    "Tôi rất thích form đầm dự tiệc ở đây. Nhân viên tư vấn nhiệt tình, ship hàng nhanh và được kiểm tra hàng thoải mái trước khi nhận."
                                </div>
                                <div class="author-detail">
                                    <div class="avatar">
                                        <img src="~/Client/img/default-user.jpg" alt="Lê Giang – TP.HCM">
                                    </div>
                                    <div class="author-content">
                                        <b>Lê Giang – TP.HCM</b>
                                        <span>Kinh doanh tự do</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="swiper-pagination mt-4"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 7. Partner Brands Section -->
<section class="section_brands" style="padding: 40px 0; background-color: #ffffff; border-top: 1px solid #e2e8f0;">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-4 mb-4 mb-lg-0">
                <h5 class="font-weight-bold text-dark mb-1">Phương thức thanh toán</h5>
                <p class="text-muted small mb-0">Hỗ trợ đa dạng phương thức thanh toán an toàn, bảo mật cao.</p>
            </div>
            <div class="col-lg-8">
                <div class="d-flex flex-wrap justify-content-start justify-content-lg-end align-items-center gap-4">
                    <img src="https://bizweb.dktcdn.net/100/601/974/themes/1047016/assets/img_brand_1.jpg?1776407985038" alt="Partner 1" style="max-height: 40px; filter: grayscale(1); opacity: 0.7; transition: all 0.3s;" onmouseover="this.style.filter='none'; this.style.opacity='1'" onmouseout="this.style.filter='grayscale(1)'; this.style.opacity='0.7'">
                    <img src="https://bizweb.dktcdn.net/100/601/974/themes/1047016/assets/img_brand_2.jpg?1776407985038" alt="Partner 2" style="max-height: 40px; filter: grayscale(1); opacity: 0.7; transition: all 0.3s;" onmouseover="this.style.filter='none'; this.style.opacity='1'" onmouseout="this.style.filter='grayscale(1)'; this.style.opacity='0.7'">
                    <img src="https://bizweb.dktcdn.net/100/601/974/themes/1047016/assets/img_brand_3.jpg?1776407985038" alt="Partner 3" style="max-height: 40px; filter: grayscale(1); opacity: 0.7; transition: all 0.3s;" onmouseover="this.style.filter='none'; this.style.opacity='1'" onmouseout="this.style.filter='grayscale(1)'; this.style.opacity='0.7'">
                    <img src="https://bizweb.dktcdn.net/100/601/974/themes/1047016/assets/img_brand_4.jpg?1776407985038" alt="Partner 4" style="max-height: 40px; filter: grayscale(1); opacity: 0.7; transition: all 0.3s;" onmouseover="this.style.filter='none'; this.style.opacity='1'" onmouseout="this.style.filter='grayscale(1)'; this.style.opacity='0.7'">
                    <img src="https://bizweb.dktcdn.net/100/601/974/themes/1047016/assets/img_brand_5.jpg?1776407985038" alt="Partner 5" style="max-height: 40px; filter: grayscale(1); opacity: 0.7; transition: all 0.3s;" onmouseover="this.style.filter='none'; this.style.opacity='1'" onmouseout="this.style.filter='grayscale(1)'; this.style.opacity='0.7'">
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Khởi tạo Swiper Slider trang chủ
            var swiperSlider = new Swiper('.section_slider .swiper-container', {
                speed: 1000,
                spaceBetween: 0,
                effect: 'fade',
                autoplay: {
                    delay: 5000,
                    disableOnInteraction: false,
                },
                pagination: {
                    el: '.section_slider .swiper-pagination',
                    clickable: true,
                },
                navigation: {
                    nextEl: '.section_slider .swiper-button-next',
                    prevEl: '.section_slider .swiper-button-prev',
                }
            });

            // Khởi tạo Swiper Feedback của khách hàng
            var swiperFeedback = new Swiper('.swiper_feedback', {
                slidesPerView: 1,
                spaceBetween: 20,
                grabCursor: true,
                autoplay: {
                    delay: 6000,
                    disableOnInteraction: false,
                },
                pagination: {
                    el: '.swiper_feedback .swiper-pagination',
                    clickable: true,
                }
            });
        });
    </script>
}
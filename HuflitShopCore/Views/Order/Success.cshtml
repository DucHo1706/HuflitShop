@{
    Layout = "_Layout";
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="page-header mb-0">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <h2 class="wow fadeInDown" data-wow-delay="0.5s">Đặt hàng thành công</h2>
            </div>
            <div class="col-12 wow fadeInUp" data-wow-delay="0.5s">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <a asp-controller="Order" asp-action="Success" asp-route-id="@ViewBag.OrderId">Thành công</a>
            </div>
        </div>
    </div>
</div>

<div class="container" style="margin-top: 2rem;">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            @if (ViewBag.PaymentSuccess == null)
            {
                <div class="alert alert-success" role="alert">
                    🎉 Đơn hàng của bạn đã được đặt thành công. Phương thức thanh toán: <strong>@ViewBag.PaymentMethodName</strong>.
                </div>
            }
            else if (ViewBag.PaymentSuccess == true)
            {
                <div class="alert alert-success" role="alert">
                    🎉 Thanh toán trực tuyến thành công qua VNPAY! Đơn hàng của bạn đang được xử lý.
                </div>
            }
            else
            {
                <div class="alert alert-danger" role="alert">
                    ❌ Thanh toán trực tuyến qua VNPAY thất bại hoặc đã bị hủy. Đơn hàng này đã bị hủy bỏ tự động. Vui lòng thử lại.
                </div>
            }

            <div class="card">
                <div class="card-body">
                    <h4 class="mb-3">Thông tin đơn</h4>

                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <strong>Mã đơn hàng:</strong>
                            <div>@ViewBag.OrderId</div>
                        </div>
                        <div class="col-md-6 mb-2">
                            <strong>Tổng thanh toán:</strong>
                            <div>@String.Format("{0:0,0}", (decimal)ViewBag.FinalAmount)</div>
                        </div>
                        <div class="col-12 mt-3">
                            <strong>Địa chỉ giao hàng:</strong>
                            <div>
                                @ViewBag.ShippingCity
                                , @ViewBag.ShippingDistrict
                                <br />
                                @ViewBag.ShippingAddress
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex" style="gap: 1rem;">
                        <a class="btn btn-primary" asp-controller="Home" asp-action="Index">Tiếp tục mua sắm</a>
                        <a class="btn btn-success" asp-controller="Product" asp-action="Product">Xem sản phẩm</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


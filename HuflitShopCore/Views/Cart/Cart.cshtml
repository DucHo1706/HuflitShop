@using HuflitShopCore.Controllers
@{
    Layout = "_Layout";
    ViewData["Title"] = "Giỏ hàng";

    var items = ViewBag.Items as IEnumerable<CartController.CartItemViewModel>;
    decimal total = ViewBag.Total is decimal d ? d : 0;
}

<div class="page-header mb-0">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <h2 class="wow fadeInDown" data-wow-delay="0.5s">Giỏ hàng</h2>
            </div>
            <div class="col-12 wow fadeInUp" data-wow-delay="0.5s">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <a asp-controller="Cart" asp-action="Cart">Giỏ hàng</a>
            </div>
        </div>
    </div>
</div>

<div class="container" style="margin-top: 2rem;">
    <div class="row">
        <div class="col-12">
            @if (items == null || !items.Any())
            {
                <div class="alert alert-info">Giỏ hàng của bạn đang trống.</div>
                <a class="btn btn-success" asp-controller="Product" asp-action="Product">Tiếp tục mua sắm</a>
            }
            else
            {
                <div class="card">
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered align-middle">
                                <thead>
                                    <tr>
                                        <th>Sản phẩm</th>
                                        <th>Kích cỡ</th>
                                        <th>Màu</th>
                                        <th>Đơn giá</th>
                                        <th>Số lượng</th>
                                        <th>Thành tiền</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in items)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@item.ProductName</strong>
                                            </td>
                                            <td>@item.SizeName</td>
                                            <td>@item.ColorName</td>
                                            <td>@String.Format("{0:0,0}", item.Price)</td>
                                            <td style="min-width: 170px;">
                                                <form asp-action="UpdateQuantity" asp-controller="Cart" method="post" class="d-flex" style="gap: 0.5rem;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="cartId" value="@item.CartId" />
                                                    <input class="form-control" type="number" name="quantity" value="@item.Quantity" min="1" />
                                                    <button class="btn btn-primary" type="submit">Cập nhật</button>
                                                </form>
                                            </td>
                                            <td>@String.Format("{0:0,0}", item.LineTotal)</td>
                                            <td>
                                                <form asp-action="Remove" asp-controller="Cart" method="post">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="cartId" value="@item.CartId" />
                                                    <button class="btn btn-danger" type="submit">Xóa</button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                        <div class="d-flex justify-content-end align-items-center" style="gap: 1rem;">
                            <div class="text-right">
                                <div class="font-weight-bold">Tổng cộng</div>
                                <div style="font-size: 1.2rem;">
                                    @String.Format("{0:0,0}", total)
                                </div>
                            </div>
                            <a class="btn btn-success" asp-controller="Order" asp-action="Checkout">Thanh toán</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>


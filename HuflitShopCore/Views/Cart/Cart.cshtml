@using HuflitShopCore.Controllers
@inject HuflitShopCore.Data.AppDbContext _context
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    Layout = "_Layout";
    ViewData["Title"] = "Giỏ hàng";
    var cloudName = Configuration["CloudinarySettings:CloudName"] ?? "Tên_Cloud_Của_Bạn";

    var items = ViewBag.Items as IEnumerable<CartController.CartItemViewModel>;
    decimal total = ViewBag.Total is decimal d ? d : 0;
}
<div class="cart-container">
    <h3 class="font-weight-bold text-dark mb-4"><i class="fas fa-shopping-cart text-primary mr-2"></i>Giỏ hàng của bạn</h3>

    @if (items == null || !items.Any())
    {
        <div class="cart-card text-center py-5">
            <div class="text-muted mb-4" style="font-size:1.5rem;"><i class="fas fa-shopping-basket mr-2 fa-lg text-primary"></i>Giỏ hàng của bạn đang trống</div>
            <a class="btn btn-primary btn-lg" asp-controller="Product" asp-action="Product" style="border-radius: 20px;">Tiếp tục mua sắm</a>
        </div>
    }
    else
    {
        <div class="cart-card px-4">
            <div class="table-responsive">
                <table class="table cart-table mb-0">
                    <thead>
                        <tr>
                            <th style="width: 45%;">Sản phẩm</th>
                            <th class="text-center">Đơn giá</th>
                            <th class="text-center" style="width: 200px;">Số lượng</th>
                            <th class="text-center">Số tiền</th>
                            <th class="text-center" style="width: 80px;">Xoá</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in items)
                        {
                            var pv = _context.ProductVariants
                                .FirstOrDefault(v => v.Id == item.ProductVariantId);
                            var defaultImage = pv != null
                                ? _context.ProductImages
                                    .Where(i => i.ProductId == pv.ProductId)
                                    .OrderBy(i => i.ImageOrder)
                                    .FirstOrDefault()
                                : null;

                            var imageUrl = HuflitShopCore.Helpers.ImageRouteHelper.Resolve(defaultImage?.PublicId);

                            <tr class="cart-row">
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="cart-prod-img">
                                            <img src="@imageUrl" alt="@item.ProductName" />
                                        </div>
                                        <div>
                                            <div class="font-weight-bold text-dark">@item.ProductName</div>
                                            <div class="cart-variant-tag">
                                                Phân loại: @item.ColorName, Size @item.SizeName
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-center cart-price-num">@item.Price.ToString("N0") đ</td>
                                <td class="text-center">
                                    <form asp-action="UpdateQuantity" asp-controller="Cart" method="post" id="qtyForm_@item.CartId" class="d-flex align-items-center justify-content-center">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="cartId" value="@item.CartId" />
                                        <button type="button" class="cart-qty-btn" style="border-radius: 4px 0 0 4px;" onclick="changeCartQty('@item.CartId', -1)">-</button>
                                        <input type="text" name="quantity" id="qtyInput_@item.CartId" value="@item.Quantity" readonly class="cart-qty-input" />
                                        <button type="button" class="cart-qty-btn" style="border-radius: 0 4px 4px 0;" onclick="changeCartQty('@item.CartId', 1)">+</button>
                                    </form>
                                </td>
                                <td class="text-center cart-total-num">@item.LineTotal.ToString("N0") đ</td>
                                <td class="text-center">
                                    <form asp-action="Remove" asp-controller="Cart" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="cartId" value="@item.CartId" />
                                        <button class="btn-delete-cart" type="submit">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Sticky bar at bottom -->
        <div class="cart-summary-bar">
            <div>
                <a class="btn btn-outline-secondary" asp-controller="Product" asp-action="Product" style="border-radius: 4px;">
                    <i class="fas fa-arrow-left mr-2"></i>Tiếp tục mua sắm
                </a>
            </div>
            <div class="d-flex align-items-center gap-4">
                <div class="cart-summary-price-box">
                    <span class="cart-summary-total-label">Tổng thanh toán (@items.Sum(i => i.Quantity) sản phẩm):</span>
                    <span class="cart-summary-total-price">@total.ToString("N0") đ</span>
                </div>
                <a class="btn-checkout-shopee" asp-controller="Order" asp-action="Checkout">
                    MUA HÀNG
                </a>
            </div>
        </div>
    }
</div>

<script>
    function changeCartQty(cartId, delta) {
        const input = document.getElementById('qtyInput_' + cartId);
        let val = parseInt(input.value) || 1;
        val += delta;
        if (val < 1) val = 1;
        input.value = val;

        // Auto submit form to save changes
        document.getElementById('qtyForm_' + cartId).submit();
    }
</script>



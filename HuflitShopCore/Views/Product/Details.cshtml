@model HuflitShopCore.Models.Product
@using Microsoft.EntityFrameworkCore
@inject HuflitShopCore.Data.AppDbContext _context
@{
    Layout = "_Layout";
    ViewData["Title"] = Model?.ProductName ?? "Details";
    var product = Model;

    var variants = product == null
        ? Enumerable.Empty<HuflitShopCore.Models.ProductVariant>()
        : _context.ProductVariants
            .Include(pv => pv.Size)
            .Include(pv => pv.Color)
            .Where(pv => pv.ProductId == product.Id && pv.IsActive && pv.StockQuantity > 0)
            .ToList();
}

<div class="page-header mb-0">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <h2 class="wow fadeInDown" data-wow-delay="0.5s">Chi tiết sản phẩm</h2>
            </div>
            <div class="col-12 wow fadeInUp" data-wow-delay="0.5s">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <a asp-controller="Product" asp-action="Product">Product</a>
                <span>@product?.ProductName</span>
            </div>
        </div>
    </div>
</div>

<div class="container" style="margin-top: 2rem;">
    <div class="row">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    <h3 class="mb-2">@product?.ProductName</h3>
                    <div class="text-muted">
                        Giá sản phẩm: <strong id="basePrice">@String.Format("{0:0,0}", product?.CurrentPrice ?? 0)</strong>
                    </div>
                    <div class="text-muted">
                        Giá theo biến thể: <strong id="variantPrice">@String.Format("{0:0,0}", product?.CurrentPrice ?? 0)</strong>
                    </div>

                    <hr />
                    <p class="mb-0">@(product?.ProductName ?? "")</p>

                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    <h4 class="mb-3">Chọn Size & Màu</h4>

                    @if (variants == null || !variants.Any())
                    {
                        <div class="alert alert-warning">Hiện sản phẩm này chưa có biến thể còn hàng.</div>
                    }
                    else
                    {
                        <div class="mb-3">
                            <div class="text-muted">Chọn đúng biến thể để add giỏ.</div>
                        </div>

                        <!-- Shoppper-style picker (UI) -->
                        <div class="row">
                            <div class="col-12">
                                <div class="card border-0" style="background:#f8f9fa;">
                                    <div class="card-body">
                                        <form method="post" asp-controller="Product" asp-action="AddCart" id="addToCartForm">
                                            @Html.AntiForgeryToken()

                                            <div class="row">
                                                <div class="col-md-6">
                                                    <div class="form-group">
                                                        <label>Size</label>
                                                        <select class="form-control" id="sizeSelect" required>
                                                            @foreach (var s in variants.Select(v => v.Size).Where(x => x != null).GroupBy(x => x!.Id).Select(g => g.First()!))
                                                            {
                                                                <option value="@s.Id">@s.SizeName</option>
                                                            }
                                                        </select>
                                                    </div>
                                                </div>
                                                <div class="col-md-6">
                                                    <div class="form-group">
                                                        <label>Màu</label>
                                                        <select class="form-control" id="colorSelect" required>
                                                            @foreach (var c in variants.Select(v => v.Color).Where(x => x != null).GroupBy(x => x!.Id).Select(g => g.First()!))
                                                            {
                                                                <option value="@c.Id">@c.ColorName</option>
                                                            }
                                                        </select>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="form-group mt-3">
                                                <label>Số lượng</label>
                                                <input class="form-control" type="number" name="quantity" value="1" min="1" />
                                            </div>

                                            <input type="hidden" name="id" value="@product?.Id" />
                                            <input type="hidden" name="productVariantId" id="productVariantId" />

                                            <div class="d-flex" style="gap: 1rem; margin-top: 1rem;">
                                                <button type="submit" class="btn btn-success flex-fill">Thêm vào giỏ</button>

                                                <button type="button" class="btn btn-primary flex-fill" onclick="submitBuyNow();">
                                                    Mua ngay
                                                </button>
                                            </div>

                                        </form>

                                        <script>
                                            (function () {
                                                const variants = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                                                    variants.Select(v => new { v.Id, v.SizeId, v.ColorId, v.AdditionalPrice }).ToList()
                                                ));


                                                const sizeSelect = document.getElementById('sizeSelect');
                                                const colorSelect = document.getElementById('colorSelect');
                                                const variantInput = document.getElementById('productVariantId');

                                                function syncVariant() {
                                                    const sizeId = sizeSelect?.value;
                                                    const colorId = colorSelect?.value;

                                                    const match = variants.find(v => v.SizeId === sizeId && v.ColorId === colorId);
                                                    variantInput.value = match ? match.Id : '';

                                                    // Tính giá theo biến thể: product.CurrentPrice + AdditionalPrice
                                                    const base = @((product?.CurrentPrice ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture));
                                                    const additional = match && match.AdditionalPrice ? Number(match.AdditionalPrice) : 0;
                                                    const total = Number(base) + additional;

                                                    const el = document.getElementById('variantPrice');
                                                    if (el) {
                                                        el.textContent = total.toLocaleString('vi-VN', { maximumFractionDigits: 0 });
                                                    }
                                                }


                                                sizeSelect?.addEventListener('change', syncVariant);
                                                colorSelect?.addEventListener('change', syncVariant);
                                                syncVariant();
                                            })();

                                            function submitBuyNow() {
                                                const form = document.getElementById('addToCartForm');
                                                const variantInput = document.getElementById('productVariantId');

                                                if (!variantInput.value) {
                                                    alert('Vui lòng chọn đúng biến thể (Size + Màu).');
                                                    return;
                                                }

                                                form.action = '@Url.Action("BuyNow","Product")';
                                                form.method = 'post';
                                                form.submit();
                                            }
                                        </script>


                                        <hr />
                                        <a class="btn btn-outline-secondary w-100" asp-controller="Cart" asp-action="Cart">Đi tới giỏ hàng</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>


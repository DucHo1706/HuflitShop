@model HuflitShopCore.Models.Product
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    Layout = "_Layout";
    ViewData["Title"] = Model?.ProductName ?? "Chi tiết sản phẩm";
    var product = Model;
    var cloudName = Configuration["CloudinarySettings:CloudName"] ?? "Tên_Cloud_Của_Bạn";

    var variants = product?.ProductVariants == null
        ? Enumerable.Empty<HuflitShopCore.Models.ProductVariant>()
        : product.ProductVariants
            .Where(pv => pv.IsActive && pv.StockQuantity > 0)
            .ToList();

    var images = product?.ProductImages == null
        ? new List<HuflitShopCore.Models.ProductImage>()
        : product.ProductImages
            .OrderBy(img => img.ImageOrder)
            .ToList();

    var mainImageUrl = HuflitShopCore.Helpers.ImageRouteHelper.Resolve(images.FirstOrDefault()?.PublicId);
}
<div class="details-container">
    <!-- Breadcrumb -->
    <div class="product-breadcrumb">
        <a asp-controller="Home" asp-action="Index">Trang chủ</a>
        <span>&gt;</span>
        <a asp-controller="Product" asp-action="Product">Sản phẩm</a>
        <span>&gt;</span>
        <a asp-action="Category" asp-controller="Product" asp-route-id="@product?.CategoryId">@product?.Category?.CategoryName</a>
        <span>&gt;</span>
        <span class="text-dark">@product?.ProductName</span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert" style="border-radius: 6px; margin-bottom: 1.5rem;">
            <i class="fas fa-check-circle mr-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="border-radius: 6px; margin-bottom: 1.5rem;">
            <i class="fas fa-exclamation-circle mr-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <!-- Main Section -->
    <div class="product-main-card">
        <div class="row">
            <!-- Left image gallery -->
            <div class="col-md-5">
                <div class="gallery-main-img">
                    <img src="@mainImageUrl" id="mainImage" alt="@product?.ProductName" />
                </div>
                
                @if (images.Count > 1)
                {
                    <div class="gallery-thumbnails">
                        @for (var i = 0; i < images.Count; i++)
                        {
                            var imgUrl = HuflitShopCore.Helpers.ImageRouteHelper.Resolve(images[i].PublicId);
                            <div class="gallery-thumb @(i == 0 ? "active" : "")" onclick="setMainImage('@imgUrl', this)">
                                <img src="@imgUrl" alt="Thumbnail" />
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Right product actions -->
            <div class="col-md-7">
                <h1 class="product-title">@product?.ProductName</h1>
                
                <!-- Price Display box -->
                <div class="price-box">
                    <span class="price-label">Giá bán:</span>
                    <span class="price-current" id="variantPrice">@((product?.CurrentPrice ?? 0).ToString("N0"))</span>
                </div>

                @if (variants == null || !variants.Any())
                {
                    <div class="alert alert-warning font-weight-bold">
                        <i class="fas fa-exclamation-triangle mr-2"></i>Sản phẩm hiện đang hết hàng hoặc chưa có biến thể sẵn sàng.
                    </div>
                }
                else
                {
                    <!-- Hidden Select controls to keep existing form submit functionality -->
                    <select id="sizeSelect" style="display:none;" required>
                        @foreach (var s in variants.Select(v => v.Size).Where(x => x != null).GroupBy(x => x!.Id).Select(g => g.First()!))
                        {
                            <option value="@s.Id">@s.SizeName</option>
                        }
                    </select>
                    
                    <select id="colorSelect" style="display:none;" required>
                        @foreach (var c in variants.Select(v => v.Color).Where(x => x != null).GroupBy(x => x!.Id).Select(g => g.First()!))
                        {
                            <option value="@c.Id">@c.ColorName</option>
                        }
                    </select>

                    <form method="post" asp-controller="Product" asp-action="AddCart" id="addToCartForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@product?.Id" />
                        <input type="hidden" name="productVariantId" id="productVariantId" />

                        <!-- Size Pills selection -->
                        <div class="selector-group">
                            <span class="selector-label">Kích thước:</span>
                            <div class="d-flex flex-wrap" id="sizePillContainer">
                                @foreach (var s in variants.Select(v => v.Size).Where(x => x != null).GroupBy(x => x!.Id).Select(g => g.First()!))
                                {
                                    <button type="button" class="pill-btn" data-value="@s.Id" onclick="selectSizePill('@s.Id', this)">@s.SizeName</button>
                                }
                            </div>
                        </div>

                        <!-- Color Pills selection -->
                        <div class="selector-group">
                            <span class="selector-label">Màu sắc:</span>
                            <div class="d-flex flex-wrap" id="colorPillContainer">
                                @foreach (var c in variants.Select(v => v.Color).Where(x => x != null).GroupBy(x => x!.Id).Select(g => g.First()!))
                                {
                                    <button type="button" class="pill-btn" data-value="@c.Id" onclick="selectColorPill('@c.Id', this)">@c.ColorName</button>
                                }
                            </div>
                        </div>

                        <!-- Quantity counter -->
                        <div class="selector-group mb-4">
                            <span class="selector-label">Số lượng:</span>
                            <div class="d-flex align-items-center">
                                <button type="button" class="qty-btn" style="border-radius:4px 0 0 4px;" onclick="changeQty(-1)">-</button>
                                <input type="text" name="quantity" id="qtyInput" value="1" readonly class="qty-input" />
                                <button type="button" class="qty-btn" style="border-radius:0 4px 4px 0;" onclick="changeQty(1)">+</button>
                            </div>
                        </div>

                        <!-- Add to Cart / Buy Now actions -->
                        <div class="d-flex flex-wrap gap-3 mt-4">
                            <button type="submit" class="btn btn-action-cart flex-fill py-3">
                                <i class="fas fa-cart-plus mr-2"></i>Thêm Vào Giỏ Hàng
                            </button>
                            <button type="button" class="btn btn-action-buy flex-fill py-3" onclick="submitBuyNow();">
                                <i class="fas fa-shopping-bag mr-2"></i>Mua Ngay
                            </button>
                        </div>
                    </form>
                }

                <div class="mt-4 pt-3 border-top">
                    <a class="btn btn-outline-secondary w-100" asp-controller="Cart" asp-action="Cart" style="border-radius:6px;">
                        <i class="fas fa-shopping-cart mr-2"></i>Đi Tới Giỏ Hàng Của Bạn
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Product Description Details -->
    <div class="product-info-card">
        <h3 class="info-header"><i class="fas fa-file-alt mr-2 text-primary"></i>Thông tin chi tiết</h3>
        
        <table class="info-table mb-4" style="width: 100%; max-width: 600px;">
            <tbody>
                <tr>
                    <td class="info-label">Danh mục:</td>
                    <td class="info-val">@product?.Category?.CategoryName</td>
                </tr>
                @if (!string.IsNullOrEmpty(product?.Trademark))
                {
                    <tr>
                        <td class="info-label">Thương hiệu:</td>
                        <td class="info-val">@product.Trademark</td>
                    </tr>
                }
                @if (!string.IsNullOrEmpty(product?.Origin))
                {
                    <tr>
                        <td class="info-label">Xuất xứ:</td>
                        <td class="info-val">@product.Origin</td>
                    </tr>
                }
                @if (product?.ManufactureYear > 0)
                {
                    <tr>
                        <td class="info-label">Năm sản xuất:</td>
                        <td class="info-val">@product.ManufactureYear</td>
                    </tr>
                }
            </tbody>
        </table>

        <h3 class="info-header mt-4"><i class="fas fa-book-open mr-2 text-primary"></i>Mô tả sản phẩm</h3>
        <div class="text-dark pt-2" style="font-size: 1.05rem; line-height: 1.7; white-space: pre-line;">
            @(string.IsNullOrWhiteSpace(product?.Description) ? "Hiện chưa có thông tin mô tả chi tiết cho sản phẩm này." : product.Description)
        </div>
    </div>

    <!-- Reviews Section -->
    @{
        var reviewsList = ViewBag.Reviews as List<HuflitShopCore.Models.Reviews> ?? new List<HuflitShopCore.Models.Reviews>();
        var star5Count = reviewsList.Count(r => r.RatingStars == 5);
        var star4Count = reviewsList.Count(r => r.RatingStars == 4);
        var star3Count = reviewsList.Count(r => r.RatingStars == 3);
        var star2Count = reviewsList.Count(r => r.RatingStars == 2);
        var star1Count = reviewsList.Count(r => r.RatingStars == 1);
    }
    <div class="reviews-card">
        <h3 class="info-header mb-4"><i class="fas fa-comments mr-2 text-primary"></i>Đánh giá từ khách hàng</h3>
        
        <!-- Summary Dashboard -->
        <div class="rating-summary-box">
            <div class="average-score">
                <h2>@ViewBag.AverageStars</h2>
                <div class="star-display my-1">
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (i <= Math.Round((double)(ViewBag.AverageStars ?? 0.0)))
                        {
                            <i class="fas fa-star"></i>
                        }
                        else
                        {
                            <i class="far fa-star text-muted"></i>
                        }
                    }
                </div>
                <div class="text-muted" style="font-size: 0.9rem;">@ViewBag.TotalReviews đánh giá</div>
            </div>
            
            <div class="rating-distribution">
                @{
                    int total = ViewBag.TotalReviews > 0 ? ViewBag.TotalReviews : 1;
                    int pct5 = (star5Count * 100) / total;
                    int pct4 = (star4Count * 100) / total;
                    int pct3 = (star3Count * 100) / total;
                    int pct2 = (star2Count * 100) / total;
                    int pct1 = (star1Count * 100) / total;
                }
                <div class="distribution-row">
                    <span class="distribution-label">5 sao</span>
                    <div class="distribution-bar-bg">
                        <div class="distribution-bar-fill" style="width: @pct5%;"></div>
                    </div>
                    <span class="distribution-count">@star5Count</span>
                </div>
                <div class="distribution-row">
                    <span class="distribution-label">4 sao</span>
                    <div class="distribution-bar-bg">
                        <div class="distribution-bar-fill" style="width: @pct4%;"></div>
                    </div>
                    <span class="distribution-count">@star4Count</span>
                </div>
                <div class="distribution-row">
                    <span class="distribution-label">3 sao</span>
                    <div class="distribution-bar-bg">
                        <div class="distribution-bar-fill" style="width: @pct3%;"></div>
                    </div>
                    <span class="distribution-count">@star3Count</span>
                </div>
                <div class="distribution-row">
                    <span class="distribution-label">2 sao</span>
                    <div class="distribution-bar-bg">
                        <div class="distribution-bar-fill" style="width: @pct2%;"></div>
                    </div>
                    <span class="distribution-count">@star2Count</span>
                </div>
                <div class="distribution-row">
                    <span class="distribution-label">1 sao</span>
                    <div class="distribution-bar-bg">
                        <div class="distribution-bar-fill" style="width: @pct1%;"></div>
                    </div>
                    <span class="distribution-count">@star1Count</span>
                </div>
            </div>
        </div>

        <!-- Add Review Form -->
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <div class="write-review-section">
                <h4 style="font-size: 1.1rem; font-weight: 700; color: #1f2937;" class="mb-3">
                    <i class="fas fa-pen-fancy mr-2 text-primary"></i>Viết đánh giá của bạn
                </h4>
                
                <form asp-controller="Product" asp-action="PostReview" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@product?.Id" />
                    <input type="hidden" name="ratingStars" id="ratingStarsInput" value="5" />
                    
                    <div class="mb-3">
                        <label class="form-label d-block text-muted font-weight-bold" style="font-size: 0.9rem;">Mức độ hài lòng của bạn:</label>
                        <div class="star-rating-input" id="starRatingSelector">
                            <i class="fas fa-star active" data-value="1"></i>
                            <i class="fas fa-star active" data-value="2"></i>
                            <i class="fas fa-star active" data-value="3"></i>
                            <i class="fas fa-star active" data-value="4"></i>
                            <i class="fas fa-star active" data-value="5"></i>
                        </div>
                        <span class="ml-3 text-warning font-weight-bold" id="starRatingLabel" style="font-size: 1rem; vertical-align: middle;">Tuyệt vời</span>
                    </div>
                    
                    <div class="mb-3">
                        <label for="reviewComment" class="form-label text-muted font-weight-bold" style="font-size: 0.9rem;">Chia sẻ trải nghiệm về sản phẩm:</label>
                        <textarea class="review-textarea" name="reviewComment" id="reviewComment" rows="4" placeholder="Nhập đánh giá chi tiết của bạn về chất lượng sản phẩm, dịch vụ giao hàng..." required></textarea>
                    </div>
                    
                    <button type="submit" class="btn btn-primary font-weight-bold" style="border-radius: 6px; padding: 0.6rem 2rem;">
                        Gửi Đánh Giá
                    </button>
                </form>
            </div>
        }
        else
        {
            <div class="alert alert-info mt-4" style="border-radius: 8px;">
                <i class="fas fa-info-circle mr-2"></i>Bạn cần <a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Context.Request.Path" class="font-weight-bold text-primary text-decoration-underline">Đăng nhập</a> để viết đánh giá cho sản phẩm này.
            </div>
        }

        <!-- Show Review List -->
        <div class="reviews-list">
            <h4 style="font-size: 1.15rem; font-weight: 700; color: #1f2937;" class="mb-4">
                Tất cả đánh giá (@ViewBag.TotalReviews)
            </h4>
            
            @if (!reviewsList.Any())
            {
                <div class="text-center py-5 text-muted">
                    <i class="far fa-comments fa-3x mb-3 text-light"></i>
                    <p class="mb-0">Chưa có đánh giá nào cho sản phẩm này. Hãy là người đầu tiên đánh giá!</p>
                </div>
            }
            else
            {
                foreach (var r in reviewsList)
                {
                    var firstChar = string.IsNullOrEmpty(r.User?.FullName) ? "K" : r.User.FullName.Substring(0, 1).ToUpper();
                    <div class="review-item">
                        <div class="d-flex align-items-start gap-3">
                            <div class="review-user-avatar">
                                @firstChar
                            </div>
                            <div class="flex-grow-1">
                                <div class="review-user-name">@(r.User?.FullName ?? "Khách hàng")</div>
                                <div class="review-meta d-flex flex-wrap align-items-center gap-2">
                                    <span class="text-warning">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= r.RatingStars)
                                            {
                                                <i class="fas fa-star"></i>
                                            }
                                            else
                                            {
                                                <i class="far fa-star text-muted"></i>
                                            }
                                        }
                                    </span>
                                    <span class="text-muted">Gửi ngày: @r.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                    @if (r.ProductVariant != null)
                                    {
                                        <span class="text-secondary">
                                            | Phân loại: 
                                            @(r.ProductVariant.Color?.ColorName ?? "Mặc định") - @(r.ProductVariant.Size?.SizeName ?? "Mặc định")
                                        </span>
                                    }
                                </div>
                                <div class="review-comment mt-2 text-dark font-weight-normal" style="font-size: 0.98rem;">
                                    @r.GetCommentText()
                                </div>
                                <div class="review-actions mt-2 d-flex align-items-center gap-3">
                                    <button type="button" class="btn btn-sm btn-outline-secondary vote-btn" data-review-id="@r.Id" style="font-size: 0.8rem; border-radius: 20px; padding: 0.2rem 0.75rem; display: inline-flex; align-items: center; gap: 4px;">
                                        <i class="far fa-thumbs-up"></i> Hữu ích (<span class="vote-count">@r.GetHelpfulVotes()</span>)
                                    </button>
                                </div>
                                
                                @if (!string.IsNullOrEmpty(r.GetAdminReply()))
                                {
                                    <div class="admin-reply-box mt-3 p-3 rounded border-left border-primary" style="background-color: #f0f4f8; margin-left: 2rem; border-left-width: 4px !important;">
                                        <div class="font-weight-bold text-primary mb-1" style="font-size: 0.9rem;">
                                            <i class="fas fa-reply fa-flip-both mr-1"></i> Tracy Shop trả lời:
                                        </div>
                                        <div class="text-dark" style="font-size: 0.95rem;">
                                            @r.GetAdminReply()
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

<script>
    // AJAX voting for reviews
    $(document).ready(function() {
        $(document).on('click', '.vote-btn', function() {
            var btn = $(this);
            var reviewId = btn.data('review-id');
            if (btn.hasClass('disabled')) return;

            btn.addClass('disabled');
            $.ajax({
                url: '/Product/VoteReview',
                type: 'POST',
                data: { reviewId: reviewId },
                success: function(response) {
                    if (response.success) {
                        btn.find('.vote-count').text(response.votes);
                        btn.removeClass('btn-outline-secondary').addClass('btn-primary text-white');
                        btn.find('i').removeClass('far').addClass('fas');
                    } else {
                        btn.removeClass('disabled');
                    }
                },
                error: function() {
                    btn.removeClass('disabled');
                }
            });
        });
    });

    const variants = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        variants.Select(v => new { v.Id, v.SizeId, v.ColorId, v.AdditionalPrice }).ToList()
    ));

    function setMainImage(url, el) {
        document.getElementById('mainImage').src = url;
        const thumbs = document.querySelectorAll('.gallery-thumb');
        thumbs.forEach(t => t.classList.remove('active'));
        el.classList.add('active');
    }

    function selectSizePill(val, el) {
        // Toggle active style in UI
        const pills = document.querySelectorAll('#sizePillContainer .pill-btn');
        pills.forEach(p => p.classList.remove('active'));
        el.classList.add('active');

        // Set backend hidden select value
        const select = document.getElementById('sizeSelect');
        if (select) {
            select.value = val;
        }
        syncVariant();
    }

    function selectColorPill(val, el) {
        // Toggle active style in UI
        const pills = document.querySelectorAll('#colorPillContainer .pill-btn');
        pills.forEach(p => p.classList.remove('active'));
        el.classList.add('active');

        // Set backend hidden select value
        const select = document.getElementById('colorSelect');
        if (select) {
            select.value = val;
        }
        syncVariant();
    }

    function changeQty(delta) {
        const input = document.getElementById('qtyInput');
        let val = parseInt(input.value) || 1;
        val += delta;
        if (val < 1) val = 1;
        input.value = val;
    }

    function syncVariant() {
        const sizeSelect = document.getElementById('sizeSelect');
        const colorSelect = document.getElementById('colorSelect');
        const variantInput = document.getElementById('productVariantId');

        const sizeId = sizeSelect?.value;
        const colorId = colorSelect?.value;

        const match = variants.find(v => v.SizeId === sizeId && v.ColorId === colorId);
        if (variantInput) {
            variantInput.value = match ? match.Id : '';
        }

        // Calculate final price: product.CurrentPrice + AdditionalPrice
        const base = @((product?.CurrentPrice ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture));
        const additional = match && match.AdditionalPrice ? Number(match.AdditionalPrice) : 0;
        const total = Number(base) + additional;

        const el = document.getElementById('variantPrice');
        if (el) {
            el.textContent = total.toLocaleString('vi-VN') + ' đ';
        }
    }

    function submitBuyNow() {
        const form = document.getElementById('addToCartForm');
        const variantInput = document.getElementById('productVariantId');

        if (!variantInput || !variantInput.value) {
            alert('Vui lòng chọn đúng biến thể (Kích thước & Màu sắc).');
            return;
        }

        // Set form action to BuyNow and submit
        form.action = '@Url.Action("BuyNow", "Product")';
        form.submit();
    }

    // Auto-select first size and color pills on load
    document.addEventListener("DOMContentLoaded", function() {
        const firstSize = document.querySelector('#sizePillContainer .pill-btn');
        if (firstSize) firstSize.click();

        const firstColor = document.querySelector('#colorPillContainer .pill-btn');
        if (firstColor) firstColor.click();

        // Star rating selector handler
        const stars = document.querySelectorAll('#starRatingSelector i');
        const ratingInput = document.getElementById('ratingStarsInput');
        const ratingLabel = document.getElementById('starRatingLabel');
        
        if (stars.length && ratingInput && ratingLabel) {
            const labels = {
                1: 'Tệ',
                2: 'Tạm ổn',
                3: 'Bình thường',
                4: 'Rất tốt',
                5: 'Tuyệt vời'
            };

            stars.forEach(star => {
                star.addEventListener('click', function() {
                    const val = parseInt(this.getAttribute('data-value'));
                    ratingInput.value = val;
                    ratingLabel.textContent = labels[val] || '';
                    
                    // Update classes for active stars
                    stars.forEach(s => {
                        const sVal = parseInt(s.getAttribute('data-value'));
                        if (sVal <= val) {
                            s.classList.remove('far', 'text-muted');
                            s.classList.add('fas', 'active');
                        } else {
                            s.classList.remove('fas', 'active');
                            s.classList.add('far', 'text-muted');
                        }
                    });
                });
                
                // Hover effect
                star.addEventListener('mouseover', function() {
                    const val = parseInt(this.getAttribute('data-value'));
                    stars.forEach(s => {
                        const sVal = parseInt(s.getAttribute('data-value'));
                        if (sVal <= val) {
                            s.style.color = '#fbbf24';
                        } else {
                            s.style.color = '#d1d5db';
                        }
                    });
                });
                
                star.addEventListener('mouseout', function() {
                    stars.forEach(s => {
                        s.removeAttribute('style');
                    });
                });
            });
        }
    });
</script>



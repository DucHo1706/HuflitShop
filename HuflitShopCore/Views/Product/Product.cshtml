@model IEnumerable<HuflitShopCore.Models.Product>
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    Layout = "_Layout";
    ViewData["Title"] = "Danh mục sản phẩm";
    var categories = ViewBag.Categories as IEnumerable<HuflitShopCore.Models.Category> ?? Enumerable.Empty<HuflitShopCore.Models.Category>();
    var cloudName = Configuration["CloudinarySettings:CloudName"] ?? "Tên_Cloud_Của_Bạn";
}

<div class="catalog-container">
    <div class="row">
        <!-- Sidebar filters -->
        <div class="col-lg-3">
            <form id="filterForm" method="get" action="@Url.Action((string)ViewBag.Action, "Product")" class="filter-sidebar-form">
                <!-- Keep search and category ID to preserve state -->
                @if (ViewBag.CategoryId != null)
                {
                    <input type="hidden" name="id" value="@ViewBag.CategoryId" />
                }
                @if (ViewBag.Search != null)
                {
                    <input type="hidden" name="search" value="@ViewBag.Search" />
                }

                <!-- Category Filter Card -->
                <div class="filter-card">
                    <div class="filter-header">
                        <i class="fas fa-list-ul"></i>
                        <span>Tất cả danh mục</span>
                    </div>
                    <ul class="filter-list">
                        <li class="filter-item">
                            <a href="@Url.Action("Product", "Product", new { search = ViewBag.Search })" class="filter-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Product" && ViewBag.CategoryId == null ? "active" : "")">
                                Tất cả sản phẩm
                            </a>
                        </li>
                        @foreach (var cat in categories)
                        {
                            <li class="filter-item">
                                <a href="@Url.Action("Category", "Product", new { id = cat.Id, search = ViewBag.Search })" class="filter-link @(ViewBag.CategoryId?.ToString() == cat.Id ? "active" : "")">
                                    @cat.CategoryName
                                </a>
                            </li>
                        }
                    </ul>
                </div>

                <!-- Trademark Filter Card -->
                @if (ViewBag.Trademarks != null && ((IEnumerable<string>)ViewBag.Trademarks).Any())
                {
                    <div class="filter-card">
                        <div class="filter-header">
                            <i class="fas fa-tags"></i>
                            <span>Thương hiệu</span>
                        </div>
                        <div class="filter-group">
                            <div class="form-check mb-2">
                                <input class="form-check-input filter-checkbox" type="radio" name="trademark" id="brand_all" value="" @(string.IsNullOrEmpty(ViewBag.Trademark) ? "checked" : "") />
                                <label class="form-check-label text-muted" for="brand_all">Tất cả thương hiệu</label>
                            </div>
                            @foreach (var brand in (IEnumerable<string>)ViewBag.Trademarks)
                            {
                                <div class="form-check mb-2">
                                    <input class="form-check-input filter-checkbox" type="radio" name="trademark" id="brand_@brand" value="@brand" @(ViewBag.Trademark == brand ? "checked" : "") />
                                    <label class="form-check-label" for="brand_@brand">@brand</label>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Price Range Filter Card -->
                <div class="filter-card">
                    <div class="filter-header">
                        <i class="fas fa-dollar-sign"></i>
                        <span>Khoảng giá</span>
                    </div>
                    <div class="filter-group">
                        @{
                            var minPrice = ViewBag.MinPrice as decimal?;
                            var maxPrice = ViewBag.MaxPrice as decimal?;
                            string priceVal = "";
                            if (minPrice == null && maxPrice == null) priceVal = "all";
                            else if (minPrice == null && maxPrice == 300000) priceVal = "under_300";
                            else if (minPrice == 300000 && maxPrice == 500000) priceVal = "300_500";
                            else if (minPrice == 500000 && maxPrice == 1000000) priceVal = "500_1000";
                            else if (minPrice == 1000000 && maxPrice == null) priceVal = "above_1000";
                            else priceVal = "custom";
                        }
                        <div class="form-check mb-2">
                            <input class="form-check-input price-radio" type="radio" name="priceRange" id="price_all" value="all" @(priceVal == "all" ? "checked" : "") onclick="setPriceFilter(null, null)" />
                            <label class="form-check-label" for="price_all">Tất cả giá</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input price-radio" type="radio" name="priceRange" id="price_under_300" value="under_300" @(priceVal == "under_300" ? "checked" : "") onclick="setPriceFilter(null, 300000)" />
                            <label class="form-check-label" for="price_under_300">Dưới 300.000₫</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input price-radio" type="radio" name="priceRange" id="price_300_500" value="300_500" @(priceVal == "300_500" ? "checked" : "") onclick="setPriceFilter(300000, 500000)" />
                            <label class="form-check-label" for="price_300_500">300.000₫ - 500.000₫</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input price-radio" type="radio" name="priceRange" id="price_500_1000" value="500_1000" @(priceVal == "500_1000" ? "checked" : "") onclick="setPriceFilter(500000, 1000000)" />
                            <label class="form-check-label" for="price_500_1000">500.000₫ - 1.000.000₫</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input price-radio" type="radio" name="priceRange" id="price_above_1000" value="above_1000" @(priceVal == "above_1000" ? "checked" : "") onclick="setPriceFilter(1000000, null)" />
                            <label class="form-check-label" for="price_above_1000">Trên 1.000.000₫</label>
                        </div>

                        <!-- Custom Price inputs -->
                        <div class="mt-3">
                            <label class="form-label text-muted font-weight-bold" style="font-size:0.8rem;">Tùy chọn khoảng giá:</label>
                            <div class="d-flex align-items-center gap-2">
                                <input type="number" name="minPrice" class="form-control form-control-sm price-input" id="priceMin" placeholder="Từ đ" value="@(ViewBag.MinPrice != null ? ((decimal)ViewBag.MinPrice).ToString("F0") : "")" style="border-radius:0px;" />
                                <span class="text-muted">-</span>
                                <input type="number" name="maxPrice" class="form-control form-control-sm price-input" id="priceMax" placeholder="Đến đ" value="@(ViewBag.MaxPrice != null ? ((decimal)ViewBag.MaxPrice).ToString("F0") : "")" style="border-radius:0px;" />
                            </div>
                            <button type="submit" class="btn btn-primary btn-sm w-100 mt-2 py-2" style="border-radius:0px; font-size:11px;">Áp dụng</button>
                        </div>
                    </div>
                </div>

                <!-- Sizes Filter Card -->
                @if (ViewBag.Sizes != null && ((IEnumerable<HuflitShopCore.Models.Size>)ViewBag.Sizes).Any())
                {
                    <div class="filter-card">
                        <div class="filter-header">
                            <i class="fas fa-ruler-combined"></i>
                            <span>Kích thước</span>
                        </div>
                        <div class="filter-group">
                            <div class="size-filter-grid">
                                <div class="size-box @(string.IsNullOrEmpty(ViewBag.SizeId) ? "active" : "")" onclick="setSizeFilter('')">Tất cả</div>
                                @foreach (var size in (IEnumerable<HuflitShopCore.Models.Size>)ViewBag.Sizes)
                                {
                                    <div class="size-box @(ViewBag.SizeId?.ToString() == size.Id ? "active" : "")" onclick="setSizeFilter('@size.Id')">@size.SizeName</div>
                                }
                            </div>
                            <input type="hidden" name="sizeId" id="sizeIdInput" value="@ViewBag.SizeId" />
                        </div>
                    </div>
                }

                <!-- Colors Filter Card -->
                @if (ViewBag.Colors != null && ((IEnumerable<HuflitShopCore.Models.Color>)ViewBag.Colors).Any())
                {
                    <div class="filter-card">
                        <div class="filter-header">
                            <i class="fas fa-palette"></i>
                            <span>Màu sắc</span>
                        </div>
                        <div class="filter-group">
                            <div class="color-filter-grid">
                                <div class="color-circle-box @(string.IsNullOrEmpty(ViewBag.ColorId) ? "active" : "")" onclick="setColorFilter('')" title="Tất cả màu">
                                    <span class="all-colors-icon">All</span>
                                </div>
                                @foreach (var color in (IEnumerable<HuflitShopCore.Models.Color>)ViewBag.Colors)
                                {
                                    <div class="color-circle-box @(ViewBag.ColorId?.ToString() == color.Id ? "active" : "")" onclick="setColorFilter('@color.Id')" title="@color.ColorName">
                                        <span class="color-circle" style="background-color: @(string.IsNullOrEmpty(color.HexCode) ? "#ccc" : color.HexCode);"></span>
                                    </div>
                                }
                            </div>
                            <input type="hidden" name="colorId" id="colorIdInput" value="@ViewBag.ColorId" />
                        </div>
                    </div>
                }

                <!-- Hidden Sort By Parameter -->
                <input type="hidden" name="sortBy" id="sortByInput" value="@ViewBag.SortBy" />

                <!-- Reset Filters Button -->
                <a href="@Url.Action((string)ViewBag.Action, "Product", new { id = ViewBag.CategoryId, search = ViewBag.Search })" class="btn btn-secondary btn-sm w-100 py-2" style="border-radius:0px; font-size:11px;">
                    <i class="fas fa-undo mr-1"></i> Xóa tất cả bộ lọc
                </a>
            </form>
        </div>

        <!-- Main Product Catalog -->
        <div class="col-lg-9">
            <!-- Sort Bar -->
            <div class="sort-bar">
                <div class="sort-options">
                    <span class="sort-label">Sắp xếp theo:</span>
                    <button type="button" class="sort-btn @(string.IsNullOrEmpty(ViewBag.SortBy) || ViewBag.SortBy == "popular" ? "active" : "")" onclick="changeSort('popular')">Phổ biến</button>
                    <button type="button" class="sort-btn @(ViewBag.SortBy == "newest" ? "active" : "")" onclick="changeSort('newest')">Mới nhất</button>
                </div>
                <div>
                    <select class="sort-select" onchange="changeSort(this.value)">
                        <option value="">Chọn khoảng giá</option>
                        <option value="price_asc" selected="@(ViewBag.SortBy == "price_asc")">Giá: Thấp đến Cao</option>
                        <option value="price_desc" selected="@(ViewBag.SortBy == "price_desc")">Giá: Cao đến Thấp</option>
                    </select>
                </div>
            </div>

            <!-- Product Grid -->
            <div class="row" id="productGrid">
                @if (Model == null || !Model.Any())
                {
                    <div class="col-12 text-center py-5">
                        <div class="text-muted mb-3" style="font-size: 1.5rem;"><i class="fas fa-box-open mr-2"></i>Không tìm thấy sản phẩm nào</div>
                        <a class="btn btn-primary" asp-action="Product" asp-controller="Product">Tải lại danh sách</a>
                    </div>
                }
                else
                {
                    foreach (var pro in Model)
                    {
                        var defaultImage = pro.ProductImages?
                            .OrderBy(i => i.ImageOrder)
                            .FirstOrDefault();

                        var imageUrl = HuflitShopCore.Helpers.ImageRouteHelper.Resolve(defaultImage?.PublicId);

                        var totalStock = pro.ProductVariants?
                            .Sum(pv => pv.StockQuantity) ?? 0;

                        <div class="col-md-4 col-6 product-card-wrapper" data-price="@pro.CurrentPrice">
                            <div class="catalog-item">
                                <div class="catalog-img">
                                    <img src="@imageUrl" alt="@pro.ProductName">
                                    <div class="catalog-overlay">
                                        <a asp-controller="Product" asp-action="Details" asp-route-id="@pro.Id"><i class="fas fa-eye mr-1"></i>Xem</a>
                                        @if (totalStock > 0)
                                        {
                                            <a asp-controller="Product" asp-action="BuyNow" asp-route-id="@pro.Id"><i class="fas fa-shopping-bag mr-1"></i>Mua ngay</a>
                                        }
                                    </div>
                                </div>
                                <div class="catalog-body">
                                    <h2 class="catalog-title">@pro.ProductName</h2>
                                    <div class="catalog-price-row">
                                        <div class="catalog-price">@pro.CurrentPrice.ToString("N0")đ</div>
                                        @if (totalStock > 0)
                                        {
                                            <form asp-action="AddCart" asp-controller="Product" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@pro.Id" />
                                                <button type="submit" class="catalog-btn-cart border-0">
                                                    <i class="fas fa-cart-plus"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary text-white" style="font-size:0.7rem;">Hết</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

            <!-- Pagination -->
            @if (ViewBag.TotalPages > 1)
            {
                <div class="d-flex justify-content-center mt-4 mb-4">
                    <nav aria-label="Page navigation">
                        <ul class="pagination mb-0">
                            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action((string)ViewBag.Action, "Product", new { 
                                    id = ViewBag.CategoryId, 
                                    search = ViewBag.Search, 
                                    minPrice = ViewBag.MinPrice, 
                                    maxPrice = ViewBag.MaxPrice, 
                                    trademark = ViewBag.Trademark, 
                                    sizeId = ViewBag.SizeId, 
                                    colorId = ViewBag.ColorId, 
                                    sortBy = ViewBag.SortBy, 
                                    page = ViewBag.CurrentPage - 1 
                                })" aria-label="Previous">
                                    <span aria-hidden="true">&laquo; Trở lại</span>
                                </a>
                            </li>
                            @for (int i = 1; i <= ViewBag.TotalPages; i++)
                            {
                                <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                                    <a class="page-link" href="@Url.Action((string)ViewBag.Action, "Product", new { 
                                        id = ViewBag.CategoryId, 
                                        search = ViewBag.Search, 
                                        minPrice = ViewBag.MinPrice, 
                                        maxPrice = ViewBag.MaxPrice, 
                                        trademark = ViewBag.Trademark, 
                                        sizeId = ViewBag.SizeId, 
                                        colorId = ViewBag.ColorId, 
                                        sortBy = ViewBag.SortBy, 
                                        page = i 
                                    })">@i</a>
                                </li>
                            }
                            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                                <a class="page-link" href="@Url.Action((string)ViewBag.Action, "Product", new { 
                                    id = ViewBag.CategoryId, 
                                    search = ViewBag.Search, 
                                    minPrice = ViewBag.MinPrice, 
                                    maxPrice = ViewBag.MaxPrice, 
                                    trademark = ViewBag.Trademark, 
                                    sizeId = ViewBag.SizeId, 
                                    colorId = ViewBag.ColorId, 
                                    sortBy = ViewBag.SortBy, 
                                    page = ViewBag.CurrentPage + 1 
                                })" aria-label="Next">
                                    <span aria-hidden="true">Tiếp &raquo;</span>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        </div>
    </div>
</div>

<script>
    $(document).ready(function() {
        $('.filter-checkbox').on('change', function() {
            $('#filterForm').submit();
        });
    });

    function setPriceFilter(min, max) {
        if (min !== null) {
            document.getElementById('priceMin').value = min;
        } else {
            document.getElementById('priceMin').value = '';
        }
        if (max !== null) {
            document.getElementById('priceMax').value = max;
        } else {
            document.getElementById('priceMax').value = '';
        }
        $('#filterForm').submit();
    }

    function setSizeFilter(sizeId) {
        document.getElementById('sizeIdInput').value = sizeId;
        $('#filterForm').submit();
    }

    function setColorFilter(colorId) {
        document.getElementById('colorIdInput').value = colorId;
        $('#filterForm').submit();
    }

    function changeSort(order) {
        document.getElementById('sortByInput').value = order;
        $('#filterForm').submit();
    }
</script>

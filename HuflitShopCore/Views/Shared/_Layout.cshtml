@inject HuflitShopCore.Data.AppDbContext _context
@using System.Security.Claims
@{
    var isAuth = User.Identity != null && User.Identity.IsAuthenticated;
    var userId = isAuth ? User.FindFirstValue(ClaimTypes.NameIdentifier) : null;
    string? guestCartId = Context.Request.Cookies["GuestCartId"];
    
    int cartCount = 0;
    if (_context != null)
    {
        if (isAuth && !string.IsNullOrEmpty(userId))
        {
            cartCount = _context.Carts.Where(c => c.UserId == userId).Sum(c => c.Quantity);
        }
        else if (!string.IsNullOrEmpty(guestCartId))
        {
            cartCount = _context.Carts.Where(c => c.SessionId == guestCartId).Sum(c => c.Quantity);
        }
    }

    bool isEmployeeOrAdmin = false;
    if (isAuth && !string.IsNullOrEmpty(userId) && _context != null)
    {
        isEmployeeOrAdmin = _context.UserRoles.Any(r => r.UserId == userId);
    }

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isHome = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase) && 
                 string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase);
    var headerClass = isHome ? "hea-index" : "bg-white shadow-sm";
}


@inject HuflitShopCore.Services.CartService CartService
@using System.Security.Claims
@{
    var isAuth = User.Identity != null && User.Identity.IsAuthenticated;
    var userId = isAuth ? User.FindFirstValue(ClaimTypes.NameIdentifier) : null;
    string? guestCartId = Context.Request.Cookies["GuestCartId"];

    int cartCount = 0;
    if (CartService != null)
    {
        cartCount = await CartService.GetCartCountAsync(userId, guestCartId);
    }

    bool isEmployeeOrAdmin = false;
    if (isAuth)
    {
        var role = User.FindFirst(ClaimTypes.Role)?.Value;
        isEmployeeOrAdmin = role == "Admin" || role == "Employee";
    }

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isHome = string.Equals(currentController, "Home", StringComparison.OrdinalIgnoreCase) &&
                 string.Equals(currentAction, "Index", StringComparison.OrdinalIgnoreCase);
    var headerClass = isHome ? "hea-index" : "bg-white shadow-sm";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <title>@ViewData["Title"] - HUFLIT SHOP</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="Clothing Shop, E-Commerce" name="keywords">
    <meta content="Huflit Shop - Thời trang nữ thiết kế cao cấp" name="description">

    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/Swiper/4.5.1/css/swiper.min.css">

    <link rel="stylesheet" href="~/Bean/aos_anima.css">

    <link href="~/css/chat.css" rel="stylesheet" />
    <link href="~/css/modern-custom.css" rel="stylesheet" />
    <link href="~/css/home.css" rel="stylesheet" />
    <link href="~/css/product.css" rel="stylesheet" />
    <link href="~/css/cart.css" rel="stylesheet" />

    <style>
        :root {
            --mainColor: #2563eb;
            --subColor: #1e293b;
            --textColor: #334155;
            --hover: #1d4ed8;
            --colorContact: #2563eb;
            --price: #ef4444;
            --bgFoot: #0f172a;
        }

        .modern-footer {
            background-color: var(--bgFoot);
            color: #94a3b8;
            padding: 60px 0 20px;
            font-size: 15px;
        }

            .modern-footer h5 {
                color: #ffffff;
                font-weight: 700 !important;
                margin-bottom: 20px;
                font-size: 18px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

            .modern-footer p, .modern-footer a, .modern-footer li {
                font-weight: 500 !important;
            }

            .modern-footer a {
                color: #94a3b8;
                text-decoration: none;
                transition: all 0.3s ease;
            }

                .modern-footer a:hover {
                    color: var(--mainColor);
                    padding-left: 5px;
                }

            .modern-footer .social-icons a {
                display: inline-flex;
                align-items: center;
                justify-content: center;
                width: 40px;
                height: 40px;
                background: rgba(255,255,255,0.1);
                border-radius: 50%;
                color: #fff;
                margin-right: 10px;
                font-size: 18px;
                transition: all 0.3s ease;
            }

                .modern-footer .social-icons a:hover {
                    background: var(--mainColor);
                    transform: translateY(-3px);
                    padding-left: 0;
                    color: #fff !important;
                }

            .modern-footer .contact-info li {
                margin-bottom: 12px;
                display: flex;
                align-items: flex-start;
            }

            .modern-footer .contact-info i {
                margin-top: 4px;
                margin-right: 12px;
                color: var(--mainColor);
            }

        .footer-newsletter .input-group {
            border-radius: 30px;
            overflow: hidden;
        }

        .footer-newsletter input {
            border: none;
            padding: 12px 20px;
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
        }

            .footer-newsletter input::placeholder {
                color: #94a3b8;
            }

            .footer-newsletter input:focus {
                box-shadow: none;
                background: rgba(255, 255, 255, 0.15);
                color: #fff;
            }

        .footer-newsletter button {
            background: var(--mainColor);
            color: #fff;
            border: none;
            padding: 0 25px;
            font-weight: 700;
            transition: background 0.3s;
            cursor: pointer;
        }

            .footer-newsletter button:hover {
                background: var(--hover);
            }

        .footer-bottom {
            border-top: 1px solid rgba(255,255,255,0.1);
            margin-top: 40px;
            padding-top: 20px;
        }
    </style>

</head>


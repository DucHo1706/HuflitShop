@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Từ chối truy cập";
}

<div class="text-center" style="padding: 10px 0; text-align: center;">
    <div style="font-size: 64px; color: #e74a3b; margin-bottom: 15px;">
        <i class="fas fa-shield-alt"></i>
    </div>
    <h1 class="auth-form-box__title" style="color: #e74a3b; margin-top: 0;">Không có quyền truy cập</h1>
    <p class="auth-form-box__sub" style="margin-bottom: 25px; line-height: 1.5; font-size: 15px;">
        Tài khoản của bạn không được cấp quyền truy cập vào trang quản trị (Admin/Employee). Vui lòng quay lại hoặc đăng nhập bằng tài khoản khác.
    </p>

    <div style="display: flex; flex-direction: column; gap: 12px; max-width: 320px; margin: 0 auto;">
        <a asp-controller="Home" asp-action="Index" class="auth-submit" style="text-align: center; text-decoration: none; display: block; padding: 12px 20px; border-radius: 8px; font-weight: 600; font-family: 'Outfit', sans-serif; background-color: #4e73df; color: #fff; border: none; transition: background-color 0.2s;">
            Quay lại Trang chủ
        </a>
        <a asp-controller="Login" asp-action="Logout" style="text-align: center; text-decoration: none; display: block; padding: 12px 20px; border-radius: 8px; font-weight: 600; font-family: 'Outfit', sans-serif; background-color: #858796; color: #fff; transition: background-color 0.2s;">
            Đăng nhập tài khoản khác
        </a>
    </div>
</div>

@model HuflitShopCore.DTOs.ForgotPasswordDTO
@{
    ViewData["Title"] = "Quên mật khẩu";
    Layout = "~/Views/Shared/_LayoutLogin.cshtml";
}

@if (Model?.EmailSent == true)
{
    <div style="text-align:center; padding: 20px 0;">
        <div style="width:70px;height:70px;background:#eff6ff;border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;">
            <i class="fas fa-envelope" style="font-size:1.8rem;color:#2563eb;"></i>
        </div>
        <h2 class="auth-form-box__title">Email đã gửi!</h2>
        <p style="color:#64748b;font-size:0.92rem;line-height:1.7;margin:12px 0 28px;">
            Chúng tôi đã gửi đường dẫn đặt lại mật khẩu đến email của bạn.<br>
            Vui lòng kiểm tra hộp thư (kể cả thư rác).
        </p>
        <a asp-action="Login" asp-controller="Login" class="auth-submit" style="display:block;text-align:center;text-decoration:none;line-height:50px;">
            Quay về đăng nhập
        </a>
    </div>
}
else
{
    <h1 class="auth-form-box__title">Quên mật khẩu</h1>
    <p class="auth-form-box__sub">Nhập email để nhận đường dẫn đặt lại mật khẩu.</p>

    <form asp-action="ForgotPassword">
        @Html.AntiForgeryToken()
        <div class="auth-alert" style="display:@(ViewData.ModelState.IsValid ? "none" : "block")">
            <div asp-validation-summary="ModelOnly"></div>
        </div>
        <div class="auth-field">
            <label>Địa chỉ email</label>
            <input asp-for="Email" type="email" placeholder="example@email.com" autocomplete="email" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <button type="submit" class="auth-submit" style="margin-top:8px;">Gửi email đặt lại</button>
    </form>

    <p class="auth-switch">
        <a asp-action="Login" asp-controller="Login"><i class="fas fa-arrow-left" style="margin-right:6px;"></i>Quay về đăng nhập</a>
    </p>
}

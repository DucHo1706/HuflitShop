@model HuflitShopCore.DTOs.LoginDTO
@{
    Layout = "_LayoutLogin";
    ViewData["Title"] = "Đăng nhập";
}

<h1 class="auth-form-box__title">Đăng nhập</h1>
<p class="auth-form-box__sub">Chào mừng bạn trở lại Huflit Shop!</p>

@if (!ViewData.ModelState.IsValid)
{
    <div class="auth-alert">
        <div asp-validation-summary="All"></div>
    </div>
}

<form method="post" id="form-login">
    @Html.AntiForgeryToken()
    <div class="auth-field">
        <label>Email đăng nhập</label>
        <input asp-for="Email" type="email" placeholder="example@email.com" autocomplete="email" />
        <span asp-validation-for="Email" class="text-danger"></span>
    </div>
    <div class="auth-field">
        <label>Mật khẩu</label>
        <input asp-for="Password" type="password" placeholder="••••••••" autocomplete="current-password" />
        <span asp-validation-for="Password" class="text-danger"></span>
    </div>

    <div class="auth-options">
        <label>
            <input type="checkbox" asp-for="RememberMe" /> Ghi nhớ tôi
        </label>
        <a asp-controller="Login" asp-action="ForgotPassword">Quên mật khẩu?</a>
    </div>

    <button type="submit" class="auth-submit">Đăng nhập</button>
</form>

<p class="auth-switch">
    Chưa có tài khoản? <a asp-controller="Login" asp-action="Register">Đăng ký ngay</a>
</p>

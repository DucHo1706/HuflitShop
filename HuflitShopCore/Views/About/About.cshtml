@{
    Layout = "_Layout";
    ViewData["Title"] = "Về chúng tôi - HUFLIT SHOP";
}

@* ── Page Header ── *@
<div class="hs-page-header">
    <div class="container">
        <h2 class="hs-page-header__title">Về Chúng Tôi</h2>
        <div class="hs-page-header__breadcrumb">
            <a asp-controller="Home" asp-action="Index">Trang chủ</a>
            <span>&rsaquo;</span>
            <span>Giới thiệu</span>
        </div>
    </div>
</div>

@* ── Brand Story ── *@
<section style="padding: 80px 0; background: #fff;">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <div class="hs-about__img-grid">
                    <div class="hs-about__img-main">
                        <img src="/Client/img/about.png" alt="Về HUFLIT SHOP">
                    </div>
                    <div class="hs-about__img-accent">
                        <img src="/Client/img/fashion-2.jpg" alt="Huflit Shop Fashion">
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="hs-about__content">
                    <p class="hs-about__sub">Câu chuyện thương hiệu</p>
                    <h2 class="hs-about__title">HUFLIT SHOP<br>Đồng hành cùng phong cách</h2>
                    <div class="hs-about__divider"></div>
                    <p class="hs-about__desc">
                        Với mong muốn mang đến những sản phẩm thời trang thiết kế chất lượng nhất, HUFLIT SHOP tự hào đồng hành cùng phái đẹp trên con đường tìm kiếm sự tự tin và phong thái riêng của bản thân.
                    </p>
                    <p class="hs-about__desc">
                        Mỗi dòng sản phẩm của chúng tôi từ đầm tiệc đến trang phục công sở đều được chọn lọc chất liệu kỹ lưỡng, đo may cẩn thận từng chi tiết và đảm bảo form dáng thoải mái, tôn vẻ quyến rũ tự nhiên.
                    </p>
                    <ul class="hs-about__list">
                        <li><i class="fas fa-check-circle"></i> Thiết kế độc quyền, cập nhật xu hướng mỗi mùa</li>
                        <li><i class="fas fa-check-circle"></i> Chất liệu vải cao cấp, thấm hút và giữ form tốt</li>
                        <li><i class="fas fa-check-circle"></i> Tư vấn size tận tâm, hỗ trợ 24/7</li>
                        <li><i class="fas fa-check-circle"></i> Đổi trả linh hoạt, giao hàng nhanh toàn quốc</li>
                    </ul>
                    <a class="hs-btn hs-btn--primary" asp-controller="Product" asp-action="Product">Xem sản phẩm ngay</a>
                </div>
            </div>
        </div>
    </div>
</section>

@* ── Stats Strip ── *@
<div class="hs-promo-strip" style="padding: 52px 0;">
    <div class="container">
        <div class="hs-promo-strip__inner" style="justify-content: space-evenly;">
            <div class="hs-promo-strip__item" style="flex-direction:column; text-align:center; gap:6px;">
                <span style="font-size:2.4rem;font-weight:800;color:#2563eb;line-height:1;">5,000+</span>
                <strong>Khách hàng hài lòng</strong>
            </div>
            <div class="hs-promo-strip__item" style="flex-direction:column; text-align:center; gap:6px;">
                <span style="font-size:2.4rem;font-weight:800;color:#2563eb;line-height:1;">200+</span>
                <strong>Mẫu thiết kế mỗi năm</strong>
            </div>
            <div class="hs-promo-strip__item" style="flex-direction:column; text-align:center; gap:6px;">
                <span style="font-size:2.4rem;font-weight:800;color:#2563eb;line-height:1;">63</span>
                <strong>Tỉnh thành giao hàng</strong>
            </div>
            <div class="hs-promo-strip__item" style="flex-direction:column; text-align:center; gap:6px;">
                <span style="font-size:2.4rem;font-weight:800;color:#2563eb;line-height:1;">4.9★</span>
                <strong>Đánh giá trung bình</strong>
            </div>
        </div>
    </div>
</div>

@* ── Collections Grid ── *@
<section style="padding: 80px 0; background:#f8fafc;">
    <div class="container">
        <div class="hs-section-head">
            <h2 class="hs-section-head__title">Bộ Sưu Tập Của Chúng Tôi</h2>
            <div class="hs-section-head__line"></div>
            <p class="hs-section-head__desc">Mỗi thiết kế là một câu chuyện về sự tinh tế và nữ tính</p>
        </div>
        <div class="row">
            <div class="col-md-4 mb-4">
                <div style="border-radius:12px;overflow:hidden;background:#fff;box-shadow:0 2px 16px rgba(0,0,0,0.06);">
                    <img src="/Client/img/set-1.jpg" alt="Váy Đầm Thiết Kế" style="width:100%;height:260px;object-fit:cover;display:block;">
                    <div style="padding:20px 22px 24px;">
                        <h4 style="font-size:1rem;font-weight:700;color:#0f172a;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:8px;">Váy Đầm Thiết Kế</h4>
                        <p style="font-size:0.88rem;color:#64748b;line-height:1.65;margin-bottom:16px;">Đầm tiệc, đầm xòe nhẹ nhàng mang lại vẻ thanh lịch và kiêu sa tối đa.</p>
                        <a asp-controller="Product" asp-action="Product" style="font-size:0.78rem;font-weight:700;color:#2563eb;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;">Khám phá →</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div style="border-radius:12px;overflow:hidden;background:#fff;box-shadow:0 2px 16px rgba(0,0,0,0.06);">
                    <img src="/Client/img/set-2.jpg" alt="Set Đồ Năng Động" style="width:100%;height:260px;object-fit:cover;display:block;">
                    <div style="padding:20px 22px 24px;">
                        <h4 style="font-size:1rem;font-weight:700;color:#0f172a;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:8px;">Set Đồ Năng Động</h4>
                        <p style="font-size:0.88rem;color:#64748b;line-height:1.65;margin-bottom:16px;">Sự kết hợp khoẻ khoắn giúp bạn tự tin trong học tập và dạo phố.</p>
                        <a asp-controller="Product" asp-action="Product" style="font-size:0.78rem;font-weight:700;color:#2563eb;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;">Khám phá →</a>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div style="border-radius:12px;overflow:hidden;background:#fff;box-shadow:0 2px 16px rgba(0,0,0,0.06);">
                    <img src="/Client/img/set-3.jpg" alt="Thời Trang Công Sở" style="width:100%;height:260px;object-fit:cover;display:block;">
                    <div style="padding:20px 22px 24px;">
                        <h4 style="font-size:1rem;font-weight:700;color:#0f172a;text-transform:uppercase;letter-spacing:0.06em;margin-bottom:8px;">Thời Trang Công Sở</h4>
                        <p style="font-size:0.88rem;color:#64748b;line-height:1.65;margin-bottom:16px;">Áo sơ mi lụa, quần tây thời thượng nâng tầm phong cách chuyên nghiệp.</p>
                        <a asp-controller="Product" asp-action="Product" style="font-size:0.78rem;font-weight:700;color:#2563eb;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;">Khám phá →</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

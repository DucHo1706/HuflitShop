@model HuflitShopCore.Models.AppUser
@{
    Layout = "_Layout";
    ViewData["Title"] = "Trang cá nhân";
    var orders = ViewBag.Orders as List<HuflitShopCore.DTOs.OrderDTO> ?? new List<HuflitShopCore.DTOs.OrderDTO>();
    var firstChar = string.IsNullOrEmpty(Model.FullName) ? "U" : Model.FullName.Substring(0, 1).ToUpper();
}

<style>
    :root {
        --vibrantBlue: #2563eb;
        --vibrantBlueHover: #1d4ed8;
        --vibrantCyan: #06b6d4;
        --oceanGradient: linear-gradient(135deg, #2563eb, #06b6d4);
        --dangerGradient: linear-gradient(135deg, #ef4444, #f43f5e);
    }

    body {
        background-color: #f8fafc !important;
    }

    .profile-container {
        max-width: 1200px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .profile-card {
        background: white;
        border-radius: 0;
        border: 1px solid #e2e8f0;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        border-top: 4px solid var(--vibrantBlue);
        padding: 2rem;
        margin-bottom: 1.5rem;
    }

    .profile-sidebar {
        text-align: center;
        padding: 2rem 1.5rem;
    }

    .profile-avatar-circle {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: var(--oceanGradient);
        color: white;
        font-size: 2.5rem;
        font-weight: 800;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.25rem;
        box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
    }

    .profile-name {
        font-size: 1.3rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 0.25rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .profile-email {
        font-size: 0.95rem;
        color: #64748b;
        margin-bottom: 2rem;
        font-weight: 500;
    }

    .profile-menu {
        list-style: none;
        padding: 0;
        margin: 0;
        text-align: left;
    }

    .profile-menu-item {
        margin-bottom: 0.5rem;
    }

    .profile-menu-btn {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        width: 100%;
        padding: 1rem 1.25rem;
        background: #f8fafc;
        border: 1px solid transparent;
        border-radius: 0;
        font-size: 0.95rem;
        font-weight: 700;
        color: #475569;
        cursor: pointer;
        transition: all 0.2s ease;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .profile-menu-btn:hover {
        background-color: #f1f5f9;
        color: var(--vibrantBlue);
        border-color: #e2e8f0;
    }

    .profile-menu-btn.active {
        background: var(--oceanGradient);
        color: white;
        border-color: transparent;
        box-shadow: 0 4px 10px rgba(37, 99, 235, 0.2);
    }

    .tab-pane {
        display: none;
    }

    .tab-pane.active {
        display: block;
        animation: fadeIn 0.3s ease;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(5px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .section-title {
        font-weight: 800;
        color: #0f172a;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #f1f5f9;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .form-group-custom {
        margin-bottom: 1.5rem;
    }

    .form-group-custom label {
        display: block;
        font-size: 0.85rem;
        font-weight: 700;
        color: #64748b;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-control-custom {
        width: 100%;
        padding: 0.8rem 1rem;
        font-size: 1rem;
        font-weight: 600;
        color: #0f172a;
        border: 1px solid #cbd5e1;
        border-radius: 0;
        outline: none;
        transition: all 0.2s ease;
        background: #ffffff;
    }

    .form-control-custom:focus {
        border-color: var(--vibrantBlue);
    }

    .form-control-custom:disabled {
        background-color: #f1f5f9;
        color: #94a3b8;
        cursor: not-allowed;
        border-color: #e2e8f0;
    }

    .table-responsive-custom {
        overflow-x: auto;
    }

    .order-table {
        width: 100%;
        border-collapse: collapse;
    }

    .order-table th {
        background-color: #f8fafc;
        color: #64748b;
        font-weight: 700;
        text-align: left;
        padding: 1rem;
        border-bottom: 2px solid #e2e8f0;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    .order-table td {
        padding: 1.25rem 1rem;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: middle;
        font-size: 0.95rem;
        color: #334155;
    }

    .badge-status {
        display: inline-block;
        padding: 0.4rem 0.75rem;
        border-radius: 0;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .badge-status-pending { background-color: #fef3c7; color: #d97706; }
    .badge-status-packing { background-color: #e0f2fe; color: #0284c7; }
    .badge-status-shipping { background-color: #dbeafe; color: #2563eb; }
    .badge-status-completed { background-color: #dcfce7; color: #16a34a; }
    .badge-status-cancelled { background-color: #fee2e2; color: #dc2626; }
    .badge-status-refunded { background-color: #f3e8ff; color: #7c3aed; }

    .badge-payment-paid { 
        background-color: #dcfce7; 
        color: #16a34a; 
        font-size: 0.75rem; 
        font-weight: 700; 
        padding: 0.4rem 0.75rem; 
        border-radius: 0; 
        text-transform: uppercase;
        display: inline-block;
    }
    
    .badge-payment-unpaid { 
        background-color: #fee2e2; 
        color: #dc2626; 
        font-size: 0.75rem; 
        font-weight: 700; 
        padding: 0.4rem 0.75rem; 
        border-radius: 0; 
        text-transform: uppercase;
        display: inline-block;
    }

    .btn-ocean-primary {
        background: var(--oceanGradient) !important;
        border: none !important;
        color: #fff !important;
        font-size: 0.95rem;
        font-weight: 700;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(37, 99, 235, 0.2);
        padding: 0.9rem 2rem;
        border-radius: 0;
        text-transform: uppercase;
    }

    .btn-ocean-primary:hover {
        background: linear-gradient(135deg, #1d4ed8, #0891b2) !important;
        box-shadow: 0 6px 20px rgba(37, 99, 235, 0.35);
        transform: translateY(-1px);
    }

    .btn-action-outline {
        background: transparent;
        border: 2px solid var(--vibrantBlue);
        color: var(--vibrantBlue);
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
        padding: 0.5rem 1rem;
        transition: all 0.2s ease;
        border-radius: 0;
        text-decoration: none;
        display: inline-block;
        letter-spacing: 0.5px;
    }

    .btn-action-outline:hover {
        background: var(--vibrantBlue);
        color: white;
        text-decoration: none;
    }

    .btn-danger-outline {
        background: transparent;
        border: 2px solid #ef4444;
        color: #ef4444;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.8rem;
        padding: 0.5rem 1rem;
        transition: all 0.2s ease;
        border-radius: 0;
        letter-spacing: 0.5px;
    }

    .btn-danger-outline:hover {
        background: #ef4444;
        color: white;
    }
</style>

<div class="profile-container">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-0 shadow-sm border-0 font-weight-bold" role="alert">
            <i class="fas fa-check-circle mr-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-dark alert-dismissible fade show rounded-0 shadow-sm border-0 text-white font-weight-bold" role="alert" style="background-color: #1e293b;">
            <i class="fas fa-exclamation-circle mr-2 text-danger"></i>@TempData["ErrorMessage"]
            <button type="button" class="close text-white" data-dismiss="alert" aria-label="Close">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>
    }

    <div class="row">
        <div class="col-lg-3 col-md-4">
            <div class="profile-card profile-sidebar">
                <div class="profile-avatar-circle">@firstChar</div>
                <div class="profile-name">@Model.FullName</div>
                <div class="profile-email">@Model.Email</div>
                
                <ul class="profile-menu">
                    <li class="profile-menu-item">
                        <button type="button" class="profile-menu-btn active" id="tabBtnAccount" onclick="switchTab('account')">
                            <i class="fas fa-user-cog"></i>Tài khoản
                        </button>
                    </li>
                    <li class="profile-menu-item">
                        <button type="button" class="profile-menu-btn" id="tabBtnOrders" onclick="switchTab('orders')">
                            <i class="fas fa-history"></i>Lịch sử mua hàng
                        </button>
                    </li>
                </ul>
            </div>
        </div>

        <div class="col-lg-9 col-md-8">
            <div class="profile-card" style="min-height: 500px;">
                <div class="tab-pane active" id="tabContentAccount">
                    <h3 class="section-title">
                        <i class="fas fa-user-shield text-primary"></i> Thông tin tài khoản
                    </h3>
                    
                    <form asp-controller="Profile" asp-action="UpdateProfile" method="post">
                        @Html.AntiForgeryToken()
                        <div class="row">
                            <div class="col-md-6 form-group-custom">
                                <label>Họ và tên</label>
                                <input type="text" name="fullName" value="@Model.FullName" class="form-control-custom" required />
                            </div>
                            <div class="col-md-6 form-group-custom">
                                <label>Địa chỉ Email (Cố định)</label>
                                <input type="email" value="@Model.Email" class="form-control-custom" disabled />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 form-group-custom">
                                <label>Số điện thoại</label>
                                <input type="text" name="phoneNumber" value="@Model.PhoneNumber" class="form-control-custom" />
                            </div>
                            <div class="col-md-6 form-group-custom">
                                <label>Giới tính</label>
                                <select name="gender" class="form-control-custom">
                                    <option value="1" selected="@(Model.Gender == 1)">Nam</option>
                                    <option value="0" selected="@(Model.Gender == 0)">Nữ</option>
                                    <option value="2" selected="@(Model.Gender == 2)">Khác</option>
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 form-group-custom">
                                <label>Ngày sinh</label>
                                <input type="date" name="dateOfBirth" value="@(Model.DateOfBirth?.ToString("yyyy-MM-dd"))" class="form-control-custom" />
                            </div>
                            <div class="col-md-6 form-group-custom">
                                <label>Ngày tham gia</label>
                                <input type="text" value="@Model.JoinedDate.ToString("dd/MM/yyyy")" class="form-control-custom" disabled />
                            </div>
                        </div>

                        <button type="submit" class="btn btn-ocean-primary mt-3">
                            Lưu Thay Đổi
                        </button>
                    </form>
                </div>

                <div class="tab-pane" id="tabContentOrders">
                    <h3 class="section-title">
                        <i class="fas fa-box-open text-primary"></i> Lịch sử mua hàng
                    </h3>
                    
                    @if (!orders.Any())
                    {
                        <div class="text-center py-5 mt-4 text-muted">
                            <i class="fas fa-receipt fa-4x mb-4" style="color: #e2e8f0;"></i>
                            <h5 class="font-weight-bold text-dark text-uppercase mb-3">Chưa có đơn hàng nào</h5>
                            <p class="mb-4">Bạn chưa thực hiện bất kỳ giao dịch nào trên hệ thống.</p>
                            <a asp-controller="Product" asp-action="Product" class="btn btn-ocean-primary">Bắt Đầu Mua Sắm</a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive-custom">
                            <table class="order-table">
                                <thead>
                                    <tr>
                                        <th>Mã ĐH</th>
                                        <th>Ngày mua</th>
                                        <th>Tổng tiền</th>
                                        <th>Thanh toán</th>
                                        <th>Trạng thái</th>
                                        <th>Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var o in orders)
                                    {
                                        <tr>
                                            <td style="font-weight: 800; color: #0f172a;">#@o.Id.Substring(0, 8).ToUpper()</td>
                                            <td style="font-weight: 600;">@o.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td style="font-weight: 800; color: #ef4444; font-size: 1.1rem;">@o.FinalAmount.ToString("N0") đ</td>
                                            <td>
                                                @if (o.PaymentStatus == 1)
                                                {
                                                    <span class="badge-payment-paid"><i class="fas fa-check mr-1"></i>Đã thu</span>
                                                }
                                                else
                                                {
                                                    <span class="badge-payment-unpaid"><i class="fas fa-clock mr-1"></i>Chưa thu</span>
                                                }
                                            </td>
                                            <td>
                                                @if (o.OrderStatus == 0)
                                                {
                                                    <span class="badge-status badge-status-pending">Chờ duyệt</span>
                                                }
                                                else if (o.OrderStatus == 1)
                                                {
                                                    <span class="badge-status badge-status-packing">Đóng gói</span>
                                                }
                                                else if (o.OrderStatus == 2)
                                                {
                                                    <span class="badge-status badge-status-shipping">Đang giao</span>
                                                }
                                                else if (o.OrderStatus == 3)
                                                {
                                                    <span class="badge-status badge-status-completed">Hoàn thành</span>
                                                }
                                                else if (o.OrderStatus == 4)
                                                {
                                                    <span class="badge-status badge-status-cancelled">Đã hủy</span>
                                                }
                                                else if (o.OrderStatus == 5)
                                                {
                                                    <span class="badge-status badge-status-refunded">Yêu cầu hoàn tiền</span>
                                                }
                                            </td>
                                            <td>
                                                <div class="d-flex flex-wrap gap-2">
                                                    <a class="btn-action-outline" href="@Url.Action("OrderDetail", "Profile", new { id = o.Id })">
                                                        Xem
                                                    </a>
                                                    @if (o.OrderStatus == 0)
                                                    {
                                                        <form asp-controller="Profile" asp-action="CancelOrder" asp-route-id="@o.Id" method="post" class="m-0" onsubmit="return confirm('Bạn có chắc chắn muốn hủy đơn hàng này?')">
                                                            @Html.AntiForgeryToken()
                                                            <button type="submit" class="btn-danger-outline">
                                                                Hủy
                                                            </button>
                                                        </form>
                                                    }
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function switchTab(tabName) {
        document.querySelectorAll('.profile-menu-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelectorAll('.tab-pane').forEach(pane => pane.classList.remove('active'));
        if (tabName === 'account') {
            document.getElementById('tabBtnAccount').classList.add('active');
            document.getElementById('tabContentAccount').classList.add('active');
        } else if (tabName === 'orders') {
            document.getElementById('tabBtnOrders').classList.add('active');
            document.getElementById('tabContentOrders').classList.add('active');
        }
    }
</script>
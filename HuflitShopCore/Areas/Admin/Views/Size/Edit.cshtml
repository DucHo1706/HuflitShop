@model HuflitShopCore.DTOs.SizeDTO
@{
    ViewData["Title"] = "Chỉnh sửa kích thước";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <h2>Chỉnh sửa kích thước</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                
                <div class="form-group mb-3">
                    <label asp-for="SizeName" class="control-label fw-bold">Tên kích thước <span class="text-danger">*</span></label>
                    <input asp-for="SizeName" class="form-control" />
                    <span asp-validation-for="SizeName" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label asp-for="SizeType" class="control-label fw-bold">Phân loại (SizeType) <span class="text-danger">*</span></label>
                    <input asp-for="SizeType" class="form-control" list="sizeTypeList" placeholder="Chọn hoặc nhập loại kích thước (VD: Clothes, Shoes, Hat...)" />
                    <datalist id="sizeTypeList">
                        @if (ViewBag.ExistingTypes != null)
                        {
                            foreach (var type in (List<string>)ViewBag.ExistingTypes)
                            {
                                <option value="@type"></option>
                            }
                        }
                    </datalist>
                    <span asp-validation-for="SizeType" class="text-danger"></span>
                </div>
                
                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-primary">Cập nhật thay đổi</button>
                    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
                </div>
            </form>
        </div>
    </div>
</div>
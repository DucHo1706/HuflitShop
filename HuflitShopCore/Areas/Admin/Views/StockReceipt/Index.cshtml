@model IEnumerable<HuflitShopCore.DTOs.StockReceiptDTO>

@{
    ViewData["Title"] = "Lịch sử nhập kho";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Lịch sử nhập kho</h1>
        <a asp-action="Create" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
            <i class="fas fa-plus fa-sm text-white-50"></i> Tạo phiếu nhập mới
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped" id="dataTable" width="100%" cellspacing="0">
                    <thead class="thead-dark">
                        <tr>
                            <th>Mã Phiếu</th>
                            <th>Ngày nhập</th>
                            <th>Nhà cung cấp</th>
                            <th>Tổng tiền</th>
                            <th class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Id</td>
                                    <td>@item.ReceiptDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@item.SupplierName</td>
                                    <td class="text-danger font-weight-bold">@item.TotalAmount.ToString("N0") VNĐ</td>
                                    <td class="text-center">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                                            <i class="fas fa-eye"></i> Xem chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else { <tr><td colspan="5" class="text-center">Chưa có dữ liệu phiếu nhập kho</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
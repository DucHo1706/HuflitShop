@model HuflitShopCore.DTOs.StockReceiptDTO

@{
    ViewData["Title"] = "Chi tiết Phiếu Nhập Kho";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<style>
    .admin-container {
        padding: 1.5rem 1rem;
        background-color: #f8fafc;
        min-height: calc(100vh - 60px);
    }

    .admin-page-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 0;
        letter-spacing: -0.5px;
    }

    .admin-card {
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        border: 1px solid #e2e8f0;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .card-header-modern {
        font-size: 1.1rem;
        font-weight: 800;
        color: #0f172a;
        padding-bottom: 1rem;
        border-bottom: 2px solid #e2e8f0;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .info-label {
        font-size: 0.85rem;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        margin-bottom: 0.3rem;
    }

    .info-value {
        font-size: 1.05rem;
        font-weight: 600;
        color: #0f172a;
        background: #f8fafc;
        padding: 0.6rem 1rem;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
    }

    .form-control {
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        padding: 0.6rem 1rem;
        font-size: 0.95rem;
        background-color: #f8fafc;
        color: #334155;
    }

        .form-control:focus {
            border-color: #10b981;
            background-color: #fff;
            box-shadow: 0 0 0 3px rgba(16,185,129,0.1);
            outline: none;
        }

    .table-admin {
        width: 100%;
        border-collapse: separate;
        margin-top: 1rem;
    }

        .table-admin th {
            background-color: #f8fafc;
            color: #64748b;
            font-weight: 700;
            font-size: 0.85rem;
            text-transform: uppercase;
            padding: 1rem;
            border-bottom: 2px solid #e2e8f0;
            border-top: none;
        }

        .table-admin td {
            padding: 1rem;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
            font-weight: 600;
            color: #334155;
        }

    .btn-admin-success {
        background: linear-gradient(135deg, #10b981, #14b8a6);
        color: #ffffff;
        border: none;
        font-weight: 700;
        padding: 0.7rem 1.5rem;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        text-transform: uppercase;
        font-size: 0.9rem;
        transition: all 0.3s;
    }

        .btn-admin-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(16,185,129,0.2);
            color: white;
        }

    .btn-admin-secondary {
        background: #ffffff;
        border: 2px solid #cbd5e1;
        color: #475569;
        font-weight: 700;
        padding: 0.6rem 1.5rem;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        text-transform: uppercase;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.2s;
    }

        .btn-admin-secondary:hover {
            background: #f8fafc;
            color: #0f172a;
            border-color: #94a3b8;
            text-decoration: none;
        }
</style>

<div class="container-fluid admin-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="admin-page-title">Chi tiết Phiếu Nhập Kho</h1>
            <p class="text-muted small mb-0 mt-1">Thông tin mã phiếu: <strong class="text-dark">#@Model.Id[..8]</strong></p>
        </div>
        <a asp-action="Index" class="btn-admin-secondary">
            <i class="fas fa-arrow-left"></i> Quay lại lịch sử
        </a>
    </div>

    <div class="admin-card" style="border-top: 4px solid #2563eb;">
        <div class="card-header-modern text-primary">
            <i class="fas fa-receipt"></i> Thông tin phiếu nhập
        </div>
        <div class="row">
            <div class="col-md-4 mb-3">
                <div class="info-label">Ngày nhập kho</div>
                <div class="info-value"><i class="far fa-calendar-alt text-muted mr-2"></i>@Model.ReceiptDate.ToString("dd/MM/yyyy HH:mm")</div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="info-label">Nhà cung cấp</div>
                <div class="info-value"><i class="fas fa-truck text-muted mr-2"></i>@Model.SupplierName</div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="info-label">Tổng tiền (VNĐ)</div>
                <div class="info-value text-danger" style="font-size: 1.25rem;">@Model.TotalAmount.ToString("N0") ₫</div>
            </div>
        </div>
    </div>

    <div class="admin-card" style="border-top: 4px solid #10b981;">
        <div class="card-header-modern text-success">
            <i class="fas fa-box-open"></i> Thêm Sản phẩm vào phiếu nhập
        </div>

        <form asp-action="AddDetails" method="post">
            <input type="hidden" name="ReceiptId" value="@Model.Id" />

            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="info-label">Sản phẩm cần thêm <span class="text-danger">*</span></label>
                    <select id="product-select" class="form-control">
                        <option value="">-- Chọn sản phẩm --</option>
                        @if (ViewBag.ProductList != null)
                        {
                            foreach (var item in ViewBag.ProductList)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <div id="variant-matrix-container" style="display:none;">
                <div class="p-3 mb-4 rounded" style="background-color: #f0fdf4; border: 1px dashed #6ee7b7;">
                    <div class="table-responsive">
                        <table class="table table-admin mb-0">
                            <thead>
                                <tr>
                                    <th>Màu sắc</th>
                                    <th>Kích thước</th>
                                    <th class="text-center">Tồn kho hiện tại</th>
                                    <th>Số lượng nhập</th>
                                    <th>Đơn giá (VNĐ)</th>
                                </tr>
                            </thead>
                            <tbody id="variant-matrix-body">
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="d-flex justify-content-end">
                    <button type="submit" class="btn-admin-success">
                        <i class="fas fa-check-circle"></i> Thêm vào phiếu
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Khi submit, lọc bỏ các chi tiết có Quantity == 0 hoặc rỗng
            $('form').on('submit', function (e) {
                var hasAnyQuantity = false;

                $('#variant-matrix-body tr').each(function (index) {
                    var qtyInput = $(this).find('input[name$=".Quantity"]');
                    var priceInput = $(this).find('input[name$=".UnitPrice"]');
                    var variantInput = $(this).find('input[name$=".ProductVariantId"]');

                    var qty = parseFloat(qtyInput.val());
                    if (qty > 0) {
                        hasAnyQuantity = true;
                        // Cập nhật lại chỉ số (index) liên tục để ASP.NET Model Binder nhận đúng list Details
                        var newIndex = $('#variant-matrix-body tr').filter(function () {
                            return parseFloat($(this).find('input[name$=".Quantity"]').val()) > 0;
                        }).index(this);

                        variantInput.attr('name', `details[${newIndex}].ProductVariantId`);
                        qtyInput.attr('name', `details[${newIndex}].Quantity`);
                        priceInput.attr('name', `details[${newIndex}].UnitPrice`);
                    } else {
                        // Vô hiệu hóa input của dòng này để không gửi lên server
                        variantInput.prop('disabled', true);
                        qtyInput.prop('disabled', true);
                        priceInput.prop('disabled', true);
                    }
                });

                if (!hasAnyQuantity) {
                    e.preventDefault();
                    alert("Vui lòng nhập số lượng > 0 cho ít nhất 1 biến thể!");

                    // Phục hồi disabled state nếu validation fail
                    $('#variant-matrix-body input').prop('disabled', false);
                    return false;
                }
            });

            $('#product-select').on('change', function () {
                var productId = $(this).val();
                var container = $('#variant-matrix-container');
                var tbody = $('#variant-matrix-body');
                tbody.empty();

                if (productId) {
                    container.show();
                    tbody.html('<tr><td colspan="5" class="text-center text-success py-3"><i class="fas fa-spinner fa-spin mr-2"></i> Đang tải dữ liệu...</td></tr>');

                    $.getJSON('@Url.Action("GetVariantsByProduct", "StockReceipt")', { productId: productId }, function (data) {
                        tbody.empty();
                        if (data.length === 0) {
                            tbody.html('<tr><td colspan="5" class="text-center text-danger font-weight-bold py-3">Sản phẩm này chưa có biến thể.</td></tr>');
                            return;
                        }

                        $.each(data, function (i, item) {
                            var row = `
                                        <tr>
                                            <td>${item.color}</td>
                                            <td>${item.size}</td>
                                            <td class="text-center"><span class="badge" style="background:#f1f5f9; color:#475569; font-size:0.9rem;">${item.stock}</span></td>
                                            <td>
                                                <input type="hidden" name="details[${i}].ProductVariantId" value="${item.id}" />
                                                <input type="number" name="details[${i}].Quantity" class="form-control text-center font-weight-bold" style="max-width: 120px;" min="0" value="0" />
                                            </td>
                                            <td>
                                                <input type="number" name="details[${i}].UnitPrice" class="form-control unit-price font-weight-bold text-danger" style="max-width: 150px;" min="0" value="0" />
                                            </td>
                                        </tr>`;
                            tbody.append(row);
                        });
                    });
                } else {
                    container.hide();
                }
            });
        });
    </script>
}
@model HuflitShopCore.DTOs.StockReceiptDTO

@{
    ViewData["Title"] = "Tạo phiếu nhập kho";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<style>
    .admin-container {
        padding: 1.5rem 1rem;
        background-color: #f8fafc;
        min-height: calc(100vh - 60px);
    }

    .admin-page-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 0;
        letter-spacing: -0.5px;
    }

    .admin-card {
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        border: 1px solid #e2e8f0;
        border-top: 4px solid #2563eb;
        padding: 2rem;
        margin-top: 1.5rem;
    }

    .form-control {
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        background-color: #f8fafc;
        color: #334155;
        transition: all 0.2s;
    }

        .form-control:focus {
            border-color: #2563eb;
            background-color: #fff;
            box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
            outline: none;
        }

    .control-label {
        font-weight: 700;
        color: #475569;
        font-size: 0.85rem;
        text-transform: uppercase;
        margin-bottom: 0.6rem;
        display: block;
    }

    .section-title {
        font-size: 1.1rem;
        font-weight: 800;
        color: #0f172a;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #e2e8f0;
        margin-bottom: 1.5rem;
        margin-top: 2rem;
    }

    .table-admin {
        width: 100%;
        border-collapse: separate;
        margin-top: 1rem;
    }

        .table-admin th {
            background-color: #f8fafc;
            color: #64748b;
            font-weight: 700;
            font-size: 0.85rem;
            text-transform: uppercase;
            padding: 1rem;
            border-bottom: 2px solid #e2e8f0;
            border-top: none;
        }

        .table-admin td {
            padding: 1rem;
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
            font-weight: 600;
            color: #334155;
        }

    .btn-admin-primary {
        background: linear-gradient(135deg, #2563eb, #06b6d4);
        color: #ffffff;
        border: none;
        font-weight: 700;
        padding: 0.8rem 1.5rem;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        cursor: pointer;
        text-transform: uppercase;
        font-size: 0.9rem;
        transition: all 0.3s;
    }

        .btn-admin-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(37,99,235,0.2);
            color: white;
        }

    .btn-admin-secondary {
        background: #ffffff;
        border: 2px solid #cbd5e1;
        color: #475569;
        font-weight: 700;
        padding: 0.7rem 1.5rem;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        text-transform: uppercase;
        text-decoration: none;
        font-size: 0.9rem;
        transition: all 0.2s;
    }

        .btn-admin-secondary:hover {
            background: #f8fafc;
            color: #0f172a;
            border-color: #94a3b8;
            text-decoration: none;
        }
</style>

<div class="container-fluid admin-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="admin-page-title">Tạo phiếu nhập kho</h1>
            <p class="text-muted small mb-0 mt-1">Khai báo thông tin nhập hàng từ nhà cung cấp</p>
        </div>
        <a asp-action="Index" class="btn-admin-secondary" style="width: auto;">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>

    <form asp-action="Create" method="post" class="admin-card">
        <div asp-validation-summary="All" class="alert alert-danger rounded font-weight-bold border-0" style="background-color: #fee2e2; color: #dc2626; display: none;"></div>
        <div id="debug-details" class="text-muted" style="font-size:12px; display:none;"></div>

        <div class="section-title"><i class="fas fa-info-circle text-primary mr-2"></i>1. Thông tin chung</div>
        <div class="row">
            <div class="form-group mb-4 col-md-6">
                <label asp-for="SupplierId" class="control-label">Nhà cung cấp <span class="text-danger">*</span></label>
                <select asp-for="SupplierId" class="form-control" asp-items="ViewBag.SupplierList">
                    <option value="">-- Chọn nhà cung cấp --</option>
                </select>
                <span asp-validation-for="SupplierId" class="text-danger small font-weight-bold mt-1 d-block"></span>
            </div>
        </div>

        <div class="section-title"><i class="fas fa-boxes text-primary mr-2"></i>2. Chọn Sản phẩm & Số lượng</div>
        <div class="row">
            <div class="form-group mb-4 col-md-6">
                <label class="control-label">Sản phẩm cần nhập <span class="text-danger">*</span></label>
                <select id="product-select" class="form-control">
                    <option value="">-- Chọn sản phẩm --</option>
                    @if (ViewBag.ProductList != null)
                    {
                        foreach (var item in ViewBag.ProductList)
                        {
                            <option value="@item.Value">@item.Text</option>
                        }
                    }
                </select>
            </div>
        </div>

        <div id="variant-matrix-container" style="display:none;" class="mt-2">
            <div class="p-3 mb-4 rounded" style="background-color: #f0f9ff; border: 1px dashed #93c5fd;">
                <h6 class="font-weight-bold" style="color: #1e3a8a;"><i class="fas fa-table mr-2"></i>Bảng biến thể sản phẩm</h6>
                <div class="table-responsive">
                    <table class="table table-admin">
                        <thead>
                            <tr>
                                <th>Màu sắc</th>
                                <th>Kích thước</th>
                                <th class="text-center">Tồn kho hiện tại</th>
                                <th>Số lượng nhập</th>
                                <th>Đơn giá nhập (VNĐ)</th>
                            </tr>
                        </thead>
                        <tbody id="variant-matrix-body">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end mt-4">
            <button type="submit" class="btn-admin-primary" style="width: auto;">
                <i class="fas fa-save"></i> Hoàn tất tạo phiếu
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Khi submit form, lọc bỏ các dòng có Quantity == 0 hoặc rỗng
            $('form').on('submit', function (e) {
                var valid = true;

                // Nếu chưa render variant nào thì không cho submit
                if (!window.__variantsRendered) {
                    e.preventDefault();
                    alert("Vui lòng chọn sản phẩm để nhập kho!");
                    return false;
                }

                var hasAnyQuantity = false;

                $('#variant-matrix-body tr').each(function (index) {
                    var qtyInput = $(this).find('input[name$=".Quantity"]');
                    var priceInput = $(this).find('input[name$=".UnitPrice"]');
                    var variantInput = $(this).find('input[name$=".ProductVariantId"]');

                    var qty = parseFloat(qtyInput.val());
                    if (qty > 0) {
                        hasAnyQuantity = true;
                        // Đổi lại name index thành tuần tự (0, 1, 2...) để ASP.NET Core bind được danh sách
                        var newIndex = $('#variant-matrix-body tr').filter(function () {
                            return parseFloat($(this).find('input[name$=".Quantity"]').val()) > 0;
                        }).index(this);

                        variantInput.attr('name', `Details[${newIndex}].ProductVariantId`);
                        qtyInput.attr('name', `Details[${newIndex}].Quantity`);
                        priceInput.attr('name', `Details[${newIndex}].UnitPrice`);
                    } else {
                        // Nếu Quantity = 0, vô hiệu hóa các input này để không gửi lên server
                        variantInput.prop('disabled', true);
                        qtyInput.prop('disabled', true);
                        priceInput.prop('disabled', true);
                    }
                });

                if (!hasAnyQuantity) {
                    e.preventDefault();
                    alert("Vui lòng nhập số lượng > 0 cho ít nhất 1 biến thể!");

                    // Phục hồi lại disabled nếu submit lỗi
                    $('#variant-matrix-body input').prop('disabled', false);
                    return false;
                }
            });

            $('#product-select').on('change', function () {
                var productId = $(this).val();
                var container = $('#variant-matrix-container');
                var tbody = $('#variant-matrix-body');
                tbody.empty();
                window.__variantsRendered = false;

                if (productId) {
                    container.show();
                    // Hiển thị loading
                    tbody.html('<tr><td colspan="5" class="text-center text-primary py-3"><i class="fas fa-spinner fa-spin mr-2"></i> Đang tải biến thể...</td></tr>');

                    $.getJSON('@Url.Action("GetVariantsByProduct", "StockReceipt")', { productId: productId }, function (data) {
                        tbody.empty();

                        if (data.length === 0) {
                            tbody.html('<tr><td colspan="5" class="text-center text-danger font-weight-bold py-3">Sản phẩm này chưa có biến thể/phân loại.</td></tr>');
                            return;
                        }

                        $.each(data, function (i, item) {
                            var row = `
                                        <tr>
                                            <td>${item.color}</td>
                                            <td>${item.size} ${item.isActive ? '' : '<span class="badge bg-warning text-dark ml-2">Ngừng bán</span>'}</td>
                                            <td class="text-center"><span class="badge" style="background:#f1f5f9; color:#475569; font-size:0.9rem;">${item.stock}</span></td>
                                            <td>
                                                <input type="hidden" name="Details[${i}].ProductVariantId" value="${item.id}" />
                                                <input type="number" name="Details[${i}].Quantity" class="form-control text-center font-weight-bold" style="max-width: 120px;" min="0" value="0" />
                                            </td>
                                            <td>
                                                <input type="number" step="0.01" name="Details[${i}].UnitPrice" class="form-control unit-price font-weight-bold text-danger" style="max-width: 150px;" min="0" value="0" />
                                            </td>
                                        </tr>`;
                            tbody.append(row);
                        });

                        // Render xong bảng variant -> bật cờ để cho submit
                        window.__variantsRendered = true;

                    });
                } else {
                    container.hide();
                }
            });
        });
    </script>
}
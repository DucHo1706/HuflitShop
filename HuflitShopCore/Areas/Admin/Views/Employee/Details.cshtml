@model HuflitShopCore.DTOs.EmployeeDTO
@{
    ViewData["Title"] = "Chi tiết nhân viên";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Thông tin chi tiết nhân viên</h1>
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning btn-sm shadow-sm">
                <i class="fas fa-edit fa-sm text-white-50"></i> Chỉnh sửa
            </a>
            <a asp-action="Index" class="btn btn-secondary btn-sm shadow-sm">
                <i class="fas fa-arrow-left fa-sm text-white-50"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Hồ sơ nhân viên: @Model.FullName</h6>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3 font-weight-bold">Họ và tên:</div>
                <div class="col-md-9 mb-3">@Model.FullName</div>

                <div class="col-md-3 font-weight-bold">Giới tính:</div>
                <div class="col-md-9 mb-3">@Model.GenderName</div>

                <div class="col-md-3 font-weight-bold">Ngày sinh:</div>
                <div class="col-md-9 mb-3">@(Model.DateOfBirth.HasValue ? Model.DateOfBirth.Value.ToString("dd/MM/yyyy") : "---")</div>

                <div class="col-md-3 font-weight-bold">Email:</div>
                <div class="col-md-9 mb-3">@Model.Email</div>

                <div class="col-md-3 font-weight-bold">Số điện thoại:</div>
                <div class="col-md-9 mb-3">@(string.IsNullOrEmpty(Model.PhoneNumber) ? "---" : Model.PhoneNumber)</div>

                <div class="col-md-3 font-weight-bold">Trạng thái:</div>
                <div class="col-md-9 mb-3">
                    @(Model.IsActive ? "Đang làm việc" : "Đã nghỉ việc")
                </div>
            </div>
        </div>
    </div>
</div>
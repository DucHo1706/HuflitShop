@model HuflitShopCore.DTOs.EmployeeDTO
@{
    ViewData["Title"] = "Chỉnh sửa nhân viên";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<style>
    .admin-container { padding: 1.5rem; background-color: #f8fafc; min-height: calc(100vh - 60px); }
    .admin-page-title { font-size: 1.5rem; font-weight: 800; color: #0f172a; margin-bottom: 0; letter-spacing: -0.5px; }
    .admin-card { background: #ffffff; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); border: 1px solid #e2e8f0; overflow: hidden; }
    .admin-card-header { padding: 1.25rem 1.5rem; display: flex; align-items: center; border-bottom: 1px solid #f1f5f9; font-weight: 700; color: #1e293b; text-transform: uppercase; letter-spacing: 0.5px; }
    .admin-card-body { padding: 1.5rem; }

    .form-label-modern { font-weight: 700; color: #475569; font-size: 0.85rem; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.5px; }
    .form-control-modern { border-radius: 8px; border: 1px solid #cbd5e1; padding: 0.7rem 1rem; font-size: 0.95rem; color: #0f172a; transition: all 0.2s ease; background-color: #f8fafc; width: 100%; }
    .form-control-modern:focus { border-color: #2563eb; background-color: #ffffff; box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1); outline: none; }
    .form-control-modern[readonly] { background-color: #e2e8f0; color: #64748b; cursor: not-allowed; border-color: #cbd5e1; }

    .btn-admin-primary { background: linear-gradient(135deg, #2563eb, #06b6d4); color: #ffffff; border: none; font-weight: 700; font-size: 0.95rem; padding: 0.8rem 1.5rem; border-radius: 8px; transition: all 0.3s ease; box-shadow: 0 4px 10px rgba(37, 99, 235, 0.2); display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer; text-transform: uppercase; }
    .btn-admin-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 15px rgba(37, 99, 235, 0.3); color: #ffffff; text-decoration: none; }
    .btn-admin-outline { background: #ffffff; border: 2px solid #cbd5e1; color: #475569; font-weight: 700; font-size: 0.95rem; padding: 0.7rem 1.5rem; border-radius: 8px; transition: all 0.2s ease; display: inline-flex; align-items: center; gap: 0.5rem; text-transform: uppercase; text-decoration: none; }
    .btn-admin-outline:hover { background: #f8fafc; color: #0f172a; border-color: #94a3b8; text-decoration: none; }
</style>

<div class="admin-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="admin-page-title">Chỉnh sửa thông tin</h1>
            <p class="text-muted small mb-0 mt-1">Cập nhật hồ sơ cho nhân viên: <strong class="text-dark">@Model.FullName</strong></p>
        </div>
        <a asp-action="Index" class="btn-admin-outline shadow-sm">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>

    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded shadow-sm font-weight-bold border-0" style="background-color: #fee2e2; color: #dc2626;"></div>
        }

        <div class="row">
            <div class="col-xl-8">
                <div class="admin-card mb-4">
                    <div class="admin-card-header">
                        <i class="fas fa-user-edit text-primary mr-2" style="font-size: 1.2rem;"></i> Thông tin chi tiết
                    </div>
                    <div class="admin-card-body">
                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="FullName" class="form-label-modern"></label>
                                <input asp-for="FullName" class="form-control-modern" />
                                <span asp-validation-for="FullName" class="text-danger small font-weight-bold mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label asp-for="Email" class="form-label-modern"></label>
                                <input asp-for="Email" class="form-control-modern" readonly />
                                <span asp-validation-for="Email" class="text-danger small font-weight-bold mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6 mb-4">
                                <label asp-for="PhoneNumber" class="form-label-modern"></label>
                                <input asp-for="PhoneNumber" class="form-control-modern" />
                                <span asp-validation-for="PhoneNumber" class="text-danger small font-weight-bold mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label asp-for="DateOfBirth" class="form-label-modern"></label>
                                <input asp-for="DateOfBirth" class="form-control-modern" type="date" />
                                <span asp-validation-for="DateOfBirth" class="text-danger small font-weight-bold mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6 mb-4 mb-md-0">
                                <label asp-for="Gender" class="form-label-modern"></label>
                                <select asp-for="Gender" class="form-control-modern">
                                    <option value="0">Nữ</option>
                                    <option value="1">Nam</option>
                                    <option value="2">Khác</option>
                                </select>
                                <span asp-validation-for="Gender" class="text-danger small font-weight-bold mt-1 d-block"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="IsActive" class="form-label-modern">Trạng thái làm việc</label>
                                <select asp-for="IsActive" class="form-control-modern">
                                    <option value="true">Đang làm việc (Active)</option>
                                    <option value="false">Đã nghỉ việc (Inactive)</option>
                                </select>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-xl-4">
                <div class="admin-card mb-4">
                    <div class="admin-card-header">
                        <i class="fas fa-map-marker-alt text-primary mr-2" style="font-size: 1.2rem;"></i> Địa chỉ nhân viên
                    </div>
                    <div class="admin-card-body">
                        <div class="form-group mb-4">
                            <label asp-for="City" class="form-label-modern">Tỉnh / Thành phố</label>
                            <input asp-for="City" class="form-control-modern" placeholder="Nhập tỉnh/thành phố..." />
                            <span asp-validation-for="City" class="text-danger small font-weight-bold mt-1 d-block"></span>
                        </div>
                        <div class="form-group mb-4">
                            <label asp-for="District" class="form-label-modern">Quận / Huyện</label>
                            <input asp-for="District" class="form-control-modern" placeholder="Nhập quận/huyện..." />
                            <span asp-validation-for="District" class="text-danger small font-weight-bold mt-1 d-block"></span>
                        </div>
                        <div class="form-group mb-0">
                            <label asp-for="SpecificAddress" class="form-label-modern">Địa chỉ cụ thể</label>
                            <textarea asp-for="SpecificAddress" class="form-control-modern" rows="3" placeholder="Số nhà, tên đường..."></textarea>
                            <span asp-validation-for="SpecificAddress" class="text-danger small font-weight-bold mt-1 d-block"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="d-flex justify-content-end gap-3 mt-2 mb-5 pb-4">
            <a asp-action="Index" class="btn-admin-outline">
                Hủy bỏ
            </a>
            <button type="submit" class="btn-admin-primary">
                <i class="fas fa-save"></i> Lưu Thay Đổi
            </button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
@model HuflitShopCore.DTOs.PromotionDTO

@{
    ViewData["Title"] = "Chỉnh sửa khuyến mãi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Chỉnh sửa khuyến mãi: @Model.PromoCode</h6>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="PromoCode" class="control-label font-weight-bold">Mã Khuyến mãi <span class="text-danger">*</span></label>
                            <input asp-for="PromoCode" class="form-control" />
                            <span asp-validation-for="PromoCode" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="DiscountType" class="control-label font-weight-bold">Loại giảm giá</label>
                            <select asp-for="DiscountType" class="form-control">
                                <option value="Percent">Phần trăm (%)</option>
                                <option value="FixedAmount">Số tiền cố định (VNĐ)</option>
                            </select>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="DiscountValue" class="control-label font-weight-bold">Mức giảm <span class="text-danger">*</span></label>
                            <input asp-for="DiscountValue" class="form-control" type="number" step="any" required value="@(Model.DiscountValue % 1 == 0 ? Convert.ToInt64(Model.DiscountValue).ToString() : Model.DiscountValue.ToString(System.Globalization.CultureInfo.InvariantCulture))" />
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="MinOrderAmount" class="control-label font-weight-bold">Đơn tối thiểu (VNĐ)</label>
                            <input asp-for="MinOrderAmount" class="form-control" type="number" step="any" value="@Convert.ToInt64(Model.MinOrderAmount)" />
                            <span class="text-muted"><small>Số tiền đơn hàng tối thiểu cần đạt để dùng Voucher.</small></span>
                        </div>
                        <div class="form-group mb-3" id="maxDiscountGroup">
                            <label asp-for="MaxDiscountAmount" class="control-label font-weight-bold">Giảm tối đa (VNĐ)</label>
                            <input asp-for="MaxDiscountAmount" class="form-control" type="number" step="any" value="@(Model.MaxDiscountAmount.HasValue ? Convert.ToInt64(Model.MaxDiscountAmount.Value).ToString() : "")" />
                            <span class="text-muted"><small>Giới hạn giảm tối đa (chỉ áp dụng khi giảm theo phần trăm).</small></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="UsageLimit" class="control-label font-weight-bold">Giới hạn số lần sử dụng</label>
                            <input asp-for="UsageLimit" class="form-control" type="number" placeholder="Để trống nếu không giới hạn" />
                            <span class="text-muted"><small>Tổng lượt sử dụng tối đa của mã này trên toàn hệ thống.</small></span>
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="StartDate" class="control-label font-weight-bold">Ngày bắt đầu <span class="text-danger">*</span></label>
                            <input asp-for="StartDate" class="form-control" type="datetime-local" />
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="EndDate" class="control-label font-weight-bold">Ngày kết thúc <span class="text-danger">*</span></label>
                            <input asp-for="EndDate" class="form-control" type="datetime-local" />
                        </div>
                        <div class="form-group mb-3">
                            <label asp-for="ApplicableProductId" class="control-label font-weight-bold text-dark">Áp dụng riêng cho Sản phẩm</label>
                            <select asp-for="ApplicableProductId" class="form-control select2-enable">
                                <option value="">-- Áp dụng cho cả giỏ hàng (Không giới hạn) --</option>
                                @if (ViewBag.Products != null)
                                {
                                    foreach (var prod in ViewBag.Products as List<HuflitShopCore.Models.Product>)
                                    {
                                        <option value="@prod.Id">@prod.ProductName (@prod.CurrentPrice.ToString("N0")₫)</option>
                                    }
                                }
                            </select>
                            <span class="text-muted"><small>Chọn sản phẩm nếu muốn thiết lập giảm giá trực tiếp (Flash Sale / Direct Discount).</small></span>
                        </div>
                        <div class="form-group mb-3">
                            <input type="hidden" asp-for="ComboProductIds" id="hiddenComboProductIds" />
                            <label class="control-label font-weight-bold text-dark">Mua chung theo Combo (Chọn nhiều sản phẩm)</label>
                            <select id="comboProductsSelect" class="form-control select2-enable" multiple="multiple">
                                @if (ViewBag.Products != null)
                                {
                                    foreach (var prod in ViewBag.Products as List<HuflitShopCore.Models.Product>)
                                    {
                                        <option value="@prod.Id">@prod.ProductName (@prod.CurrentPrice.ToString("N0")₫)</option>
                                    }
                                }
                            </select>
                            <span class="text-muted"><small>Chọn các sản phẩm cần mua cùng nhau để kích hoạt combo giảm giá.</small></span>
                        </div>
                        <div class="form-group form-check mt-4">
                            <label class="form-check-label font-weight-bold">
                                <input class="form-check-input" asp-for="IsActive" /> Kích hoạt khuyến mãi
                            </label>
                        </div>
                        <div class="form-group form-check mt-2">
                            <label class="form-check-label font-weight-bold text-success">
                                <input class="form-check-input" asp-for="IsAutoApply" /> Tự động áp dụng (Không cần nhập mã)
                            </label>
                            <br/><span class="text-muted"><small>Tự động tính giảm giá trực tiếp vào giỏ hàng mà khách không cần điền mã voucher.</small></span>
                        </div>
                    </div>
                </div>

                <div class="form-group mt-4">
                    <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Cập nhật</button>
                    <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Trở về danh sách</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    
    <script>
        $(document).ready(function() {
            var typeSelect = document.getElementById("DiscountType");
            var maxDiscountGroup = document.getElementById("maxDiscountGroup");
            
            function toggleMaxDiscount() {
                if (typeSelect.value === "Percent") {
                    maxDiscountGroup.style.display = "block";
                } else {
                    maxDiscountGroup.style.display = "none";
                }
            }
            
            typeSelect.addEventListener("change", toggleMaxDiscount);
            toggleMaxDiscount(); // Run once initially

            // Khởi tạo select2 cho combo và sản phẩm riêng
            $('#comboProductsSelect').select2({
                placeholder: "Chọn các sản phẩm cho combo",
                allowClear: true,
                width: '100%'
            });

            // Khi submit form, gộp các ID đã chọn bằng dấu phẩy và gán vào input ẩn
            $('form').on('submit', function() {
                var selectedIds = $('#comboProductsSelect').val() || [];
                $('#hiddenComboProductIds').val(selectedIds.join(','));
            });
            
            // Edit mode/validation fallback: Điền sẵn các giá trị đã chọn
            var initialComboVal = $('#hiddenComboProductIds').val();
            if (initialComboVal) {
                var initialIds = initialComboVal.split(',').map(s => s.trim()).filter(s => s.length > 0);
                $('#comboProductsSelect').val(initialIds).trigger('change');
            }
        });
    </script>
}
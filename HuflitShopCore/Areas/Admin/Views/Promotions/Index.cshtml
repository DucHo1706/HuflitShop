@model IEnumerable<HuflitShopCore.DTOs.PromotionDTO>
@{
    ViewData["Title"] = "Quản lý khuyến mãi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Danh sách chương trình khuyến mãi</h1>
        <a asp-action="Create" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
            <i class="fas fa-plus-circle fa-sm text-white-50"></i> Thêm khuyến mãi mới
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <table class="table table-bordered table-striped">
                <thead class="thead-dark">
                    <tr>
                        <th>Mã KM</th>
                        <th>Loại & Mức giảm</th>
                        <th>Đơn tối thiểu</th>
                        <th>Giảm tối đa</th>
                        <th>Đã dùng / Giới hạn</th>
                        <th>Thời gian áp dụng</th>
                        <th>Trạng thái</th>
                        <th style="width: 100px;" class="text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                 <td>
                                     <span class="badge bg-info text-white font-weight-bold d-inline-block mb-1" style="font-size: 0.95rem;">@item.PromoCode</span>
                                     @if (item.IsAutoApply)
                                     {
                                         <span class="badge bg-success text-white d-block mb-1" style="font-size: 0.75rem;"><i class="fas fa-magic mr-1"></i>Tự động áp dụng</span>
                                     }
                                     @if (!string.IsNullOrEmpty(item.ApplicableProductId))
                                     {
                                         <span class="badge bg-primary text-white d-block mb-1 text-truncate" style="font-size: 0.75rem; max-width: 140px;" title="ID: @item.ApplicableProductId"><i class="fas fa-box mr-1"></i>Sản phẩm riêng</span>
                                     }
                                     @if (!string.IsNullOrEmpty(item.ComboProductIds))
                                     {
                                         <span class="badge bg-dark text-white d-block mb-1 text-truncate" style="font-size: 0.75rem; max-width: 140px;" title="Combo: @item.ComboProductIds"><i class="fas fa-layer-group mr-1"></i>Combo</span>
                                     }
                                 </td>
                                <td>
                                    @if(string.Equals(item.DiscountType, "Percent", StringComparison.OrdinalIgnoreCase)) {
                                        <span class="font-weight-bold text-danger">@item.DiscountValue.ToString("0.##")%</span>
                                    } else {
                                        <span class="font-weight-bold text-danger">@item.DiscountValue.ToString("N0") đ</span>
                                    }
                                </td>
                                <td>
                                    <span class="text-dark">@item.MinOrderAmount.ToString("N0") đ</span>
                                </td>
                                <td>
                                    @if(string.Equals(item.DiscountType, "Percent", StringComparison.OrdinalIgnoreCase) && item.MaxDiscountAmount.HasValue) {
                                        <span class="text-dark">@item.MaxDiscountAmount.Value.ToString("N0") đ</span>
                                    } else {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <span class="font-weight-bold text-primary">@item.UsedCount</span> / 
                                    @(item.UsageLimit.HasValue ? item.UsageLimit.Value.ToString() : "∞")
                                </td>
                                <td>
                                    <small class="d-block text-muted">Từ: @item.StartDate.ToString("dd/MM/yyyy HH:mm")</small>
                                    <small class="d-block text-muted">Đến: @item.EndDate.ToString("dd/MM/yyyy HH:mm")</small>
                                </td>
                                <td>
                                    @if (item.IsOngoing)
                                    {
                                        @if (item.UsageLimit.HasValue && item.UsedCount >= item.UsageLimit.Value)
                                        {
                                            <span class="badge bg-danger text-white">Hết lượt dùng</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success text-white">Đang áp dụng</span>
                                        }
                                    }
                                    else if (item.StartDate > DateTime.Now && item.IsActive)
                                    {
                                        <span class="badge bg-warning text-dark">Sắp diễn ra</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary text-white">Đã kết thúc / Tắt</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm" title="Sửa"><i class="fas fa-edit"></i></a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa khuyến mãi này?');">
                                        <button type="submit" class="btn btn-danger btn-sm" title="Xóa">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                    else { <tr><td colspan="5" class="text-center">Chưa có dữ liệu khuyến mãi</td></tr> }
                </tbody>
            </table>
        </div>
    </div>
</div>
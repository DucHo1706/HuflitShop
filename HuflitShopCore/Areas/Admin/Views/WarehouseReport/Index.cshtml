@model HuflitShopCore.DTOs.WarehouseReportDTO
@{
    ViewData["Title"] = "Báo cáo Nhập - Xuất - Tồn";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<style>
    /* Tổng quan Giao diện */
    .admin-container {
        padding: 1.5rem 1rem;
        background-color: #f8fafc;
        min-height: 100vh;
    }

    .admin-page-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 1.5rem;
        letter-spacing: -0.5px;
    }

    /* Thẻ bọc (Cards) */
    .admin-card {
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
        border: 1px solid #e2e8f0;
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .card-header-modern {
        font-weight: 800;
        color: #1e293b;
        margin-bottom: 1rem;
        font-size: 1.05rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    /* KPI Cards */
    .excel-kpi-row {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1rem;
    }

    .excel-kpi-card {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        transition: 0.3s;
    }

        .excel-kpi-card:hover {
            border-color: #06b6d4;
            box-shadow: 0 4px 12px rgba(6,182,212,0.1);
        }

    .excel-kpi-title {
        font-size: 0.75rem;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
    }

    .excel-kpi-value {
        font-size: 1.25rem;
        font-weight: 800;
        color: #0f172a;
    }

    /* Form & Select2 */
    .form-control-modern {
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        padding: 0.6rem;
        font-size: 0.9rem;
    }

    .btn-filter {
        background: linear-gradient(135deg, #002d62, #134074);
        color: white;
        border-radius: 8px;
        font-weight: 700;
        padding: 0.6rem 1.5rem;
    }

    /* Bảng dữ liệu */
    .table-admin {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

        .table-admin thead th {
            background: #f8fafc;
            color: #64748b;
            font-size: 0.75rem;
            text-transform: uppercase;
            padding: 1rem;
            border-bottom: 2px solid #e2e8f0;
        }

        .table-admin td {
            padding: 1rem;
            border-bottom: 1px solid #f1f5f9;
            font-size: 0.9rem;
            font-weight: 600;
            color: #334155;
        }
</style>

<div class="container-fluid admin-container">
    <h1 class="admin-page-title"><i class="fas fa-chart-line text-primary mr-2"></i>Báo cáo Nhập - Xuất - Tồn</h1>

    <div class="admin-card">
        <form method="get" asp-action="Index" class="row align-items-end">
            <div class="col-md-2">
                <label class="control-label font-weight-bold small">Năm</label>
                <select name="year" class="form-control-modern w-100">
                    @for (int y = 2024; y <= DateTime.Now.Year + 1; y++)
                    {
                        <option value="@y" selected="@(y == Model.SelectedYear)">@y</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="control-label font-weight-bold small">Tháng</label>
                <select name="month" class="form-control-modern w-100">
                    @for (int m = 1; m <= 12; m++)
                    {
                        <option value="@m" selected="@(m == Model.SelectedMonth)">Tháng @m</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <label class="control-label font-weight-bold small">Nhà cung cấp</label>
                <select name="supplierId" class="form-control-modern w-100 select2-filter">
                    <option value="All">Tất cả nhà cung cấp</option>
                    @foreach (var s in ViewBag.SuppliersList)
                    {
                        <option value="@s.Id" selected="@(Model.SelectedSupplierId == s.Id)">@s.SupplierName</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-filter w-100"><i class="fas fa-filter mr-2"></i>Lọc dữ liệu</button>
            </div>
        </form>
    </div>

    <div class="excel-kpi-row mb-4">
        <div class="excel-kpi-card">
            <span class="excel-kpi-title">Tồn đầu kỳ</span>
            <div class="excel-kpi-value text-dark">@Model.BeginningStockValue.ToString("N0") đ</div>
        </div>
        <div class="excel-kpi-card">
            <span class="excel-kpi-title">Nhập kho</span>
            <div class="excel-kpi-value text-success">@Model.ImportStockValue.ToString("N0") đ</div>
        </div>
        <div class="excel-kpi-card">
            <span class="excel-kpi-title">Xuất kho</span>
            <div class="excel-kpi-value text-warning">@Model.ExportStockValue.ToString("N0") đ</div>
        </div>
        <div class="excel-kpi-card">
            <span class="excel-kpi-title">Tồn cuối kỳ</span>
            <div class="excel-kpi-value text-info">@Model.EndingStockValue.ToString("N0") đ</div>
        </div>
    </div>

    <div class="excel-kpi-row mb-4">
        <div class="excel-kpi-card">
            <span class="excel-kpi-title">Doanh thu gộp (Gross)</span>
            <div class="excel-kpi-value text-dark">@Model.GrossRevenue.ToString("N0") đ</div>
        </div>
        <div class="excel-kpi-card">
            <span class="excel-kpi-title">Tổng giảm giá</span>
            <div class="excel-kpi-value text-danger">@Model.TotalDiscount.ToString("N0") đ</div>
        </div>
        <div class="excel-kpi-card">
            <span class="excel-kpi-title">Doanh thu ròng (Net)</span>
            <div class="excel-kpi-value text-success">@Model.NetRevenue.ToString("N0") đ</div>
        </div>
        <div class="excel-kpi-card">
            <span class="excel-kpi-title">Thu phí ship từ khách</span>
            <div class="excel-kpi-value text-info">@Model.TotalShippingRevenue.ToString("N0") đ</div>
        </div>
    </div>

    <div class="admin-card">
        <ul class="nav nav-tabs" id="dashboardTabs">
            <li class="nav-item"><a class="nav-link active" data-toggle="tab" href="#product-content">Tổng quan sản phẩm</a></li>
            <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#profit-content">Chi tiết Lãi/Lỗ sản phẩm</a></li>
            <li class="nav-item"><a class="nav-link" data-toggle="tab" href="#chart-content">Biểu đồ doanh thu</a></li>
        </ul>
        <div class="tab-content pt-4">
            <div class="tab-pane fade show active" id="product-content">
                <table class="table table-admin table-hover">
                    <thead>
                        <tr>
                            <th>Tên sản phẩm</th>
                            <th class="text-right">Tồn đầu</th>
                            <th class="text-right">Nhập</th>
                            <th class="text-right">Xuất</th>
                            <th class="text-right">Tồn cuối</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.ProductSummaries)
                        {
                            <tr>
                                <td class="font-weight-bold text-dark">@p.ProductName</td>
                                <td class="text-right">@p.BeginningValue.ToString("N0")</td>
                                <td class="text-right text-success">@p.ImportValue.ToString("N0")</td>
                                <td class="text-right text-warning">@p.ExportValue.ToString("N0")</td>
                                <td class="text-right text-info">@p.EndingValue.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="tab-pane fade" id="profit-content">
                <table class="table table-admin table-hover">
                    <thead>
                        <tr>
                            <th>Tên sản phẩm</th>
                            <th class="text-right">Đã bán</th>
                            <th class="text-right">Doanh thu gộp</th>
                            <th class="text-right">Chiết khấu</th>
                            <th class="text-right">Doanh thu ròng</th>
                            <th class="text-right">Giá vốn (FIFO)</th>
                            <th class="text-right">Lợi nhuận gộp</th>
                            <th class="text-right">Tỉ suất LN</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ProductProfits != null && Model.ProductProfits.Any())
                        {
                            foreach (var p in Model.ProductProfits)
                            {
                                var profitClass = p.GrossProfit >= 0 ? "text-success" : "text-danger";
                                <tr>
                                    <td class="font-weight-bold text-dark">@p.ProductName</td>
                                    <td class="text-right">@p.TotalSold.ToString("N0")</td>
                                    <td class="text-right">@p.GrossRevenue.ToString("N0") đ</td>
                                    <td class="text-right text-muted">@p.DiscountAllocated.ToString("N0") đ</td>
                                    <td class="text-right">@p.NetRevenue.ToString("N0") đ</td>
                                    <td class="text-right">@p.COGS.ToString("N0") đ</td>
                                    <td class="text-right font-weight-bold @profitClass">@p.GrossProfit.ToString("N0") đ</td>
                                    <td class="text-right font-weight-bold @profitClass">@p.ProfitMargin.ToString("F1")%</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4 font-italic">Không có dữ liệu giao dịch trong kỳ này.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="tab-pane fade" id="chart-content">
                <canvas id="topRevenueChart" height="100"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function () {
            $('.select2-filter').select2({ width: '100%' });
        });

        // Giữ nguyên logic Chart của bạn tại đây
        var revenueCtx = document.getElementById("topRevenueChart").getContext("2d");
        new Chart(revenueCtx, {
            type: 'horizontalBar',
            data: {
                labels: @Html.Raw(Json.Serialize(Model.TopRevenueProducts.Select(t => t.ProductName))),
                datasets: [{
                    label: 'Doanh thu',
                    backgroundColor: '#2563eb',
                    data: @Html.Raw(Json.Serialize(Model.TopRevenueProducts.Select(t => t.Revenue)))
                        }]
            }
        });
    </script>
}
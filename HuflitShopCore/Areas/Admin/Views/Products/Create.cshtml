@model HuflitShopCore.DTOs.ProductDTO
@{
    ViewData["Title"] = "Thêm sản phẩm mới";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Thêm sản phẩm mới</h1>
        <a asp-action="Index" class="btn btn-secondary btn-sm shadow-sm">
            <i class="fas fa-arrow-left fa-sm text-white-50"></i> Quay lại
        </a>
    </div>
    <hr />
    <form asp-action="Create" method="post" class="card shadow p-4">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label asp-for="ProductName" class="control-label fw-bold">Tên sản phẩm</label>
                    <input asp-for="ProductName" class="form-control" placeholder="Nhập tên sản phẩm..." />
                    <span asp-validation-for="ProductName" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="CategoryId" class="control-label fw-bold">Chọn danh mục</label>
                    <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryList">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="CurrentPrice" class="control-label fw-bold">Giá bán (VNĐ)</label>
                    <input asp-for="CurrentPrice" class="form-control" type="number" />
                    <span asp-validation-for="CurrentPrice" class="text-danger"></span>
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label asp-for="ManufactureYear" class="control-label fw-bold">Năm sản xuất</label>
                    <input asp-for="ManufactureYear" class="form-control" type="number" />
                    <span asp-validation-for="ManufactureYear" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Trademark" class="control-label fw-bold">Thương hiệu</label>
                    <input asp-for="Trademark" class="form-control" />
                    <span asp-validation-for="Trademark" class="text-danger"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Origin" class="control-label fw-bold">Xuất xứ</label>
                    <input asp-for="Origin" class="form-control" />
                    <span asp-validation-for="Origin" class="text-danger"></span>
                </div>
            </div>
        </div>
        <div class="form-group mb-3">
            <label asp-for="Description" class="control-label fw-bold">Mô tả</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="form-group mt-3">
            <button type="submit" class="btn btn-primary">Thêm sản phẩm</button>
            <a asp-action="Index" class="btn btn-secondary">Hủy</a>
        </div>
    </form>
</div>

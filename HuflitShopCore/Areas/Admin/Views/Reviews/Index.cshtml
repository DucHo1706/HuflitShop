@model IEnumerable<HuflitShopCore.DTOs.ReviewDTO>

@{
    ViewData["Title"] = "Quản lý Đánh giá";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Danh sách phản hồi của Khách hàng</h1>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-striped" id="dataTable" width="100%" cellspacing="0">
                    <thead class="thead-dark">
                        <tr>
                            <th>Khách hàng</th>
                            <th>Sản phẩm</th>
                            <th>Đánh giá</th>
                            <th>Nội dung</th>
                            <th>Ngày gửi</th>
                            <th class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="font-weight-bold text-primary">@item.CustomerName</td>
                                    <td>@item.ProductName</td>
                                    <td class="text-warning">
                                        @for (int i = 0; i < item.Rate; i++) { <i class="fas fa-star"></i> }
                                    </td>
                                    <td>@item.Content</td>
                                    <td>@item.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-center">
                                        <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Bạn có chắc chắn muốn xóa phản hồi này?');">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn btn-danger btn-sm" title="Xóa"><i class="fas fa-trash"></i> Xóa</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                        else { <tr><td colspan="6" class="text-center">Chưa có phản hồi nào.</td></tr> }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
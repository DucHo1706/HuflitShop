@model HuflitShopCore.DTOs.OrderDTO

@{
    ViewData["Title"] = "Chi tiết Đơn Hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Chi tiết đơn hàng: <span class="text-primary" title="@Model.Id">@Model.Id.Substring(0, 8)...</span></h1>
        <a asp-action="Index" class="btn btn-sm btn-secondary shadow-sm">
            <i class="fas fa-arrow-left fa-sm text-white-50"></i> Trở về danh sách
        </a>
    </div>

    <div class="row">
        <!-- Cột trái: Thông tin đơn hàng (Danh sách sản phẩm) -->
        <div class="col-xl-8 col-lg-7">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Sản phẩm đã đặt</h6>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered text-center">
                            <thead class="thead-light">
                                <tr>
                                    <th class="text-left">Sản phẩm (Bản Snapshot)</th>
                                    <th>Đơn giá</th>
                                    <th>SL</th>
                                    <th>Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var detail in Model.OrderDetails)
                                {
                                    <tr>
                                        <td class="text-left font-weight-bold text-dark">
                                            @detail.FullProductName
                                        </td>
                                        <td>@detail.PurchasedPrice.ToString("N0") đ</td>
                                        <td>@detail.Quantity</td>
                                        <td class="text-danger font-weight-bold">@detail.TotalPrice.ToString("N0") đ</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    
                    <hr />
                    <!-- Tổng kết tiền -->
                    <div class="row justify-content-end text-right">
                        <div class="col-md-6 col-sm-12">
                            <p class="mb-1">Tạm tính: <strong>@Model.TotalAmount.ToString("N0") đ</strong></p>
                            <p class="mb-1">Phí vận chuyển: <strong>@Model.ShippingFee.ToString("N0") đ</strong></p>
                            <p class="mb-1">Giảm giá: <strong class="text-success">- @Model.DiscountAmount.ToString("N0") đ</strong></p>
                            @if (!string.IsNullOrEmpty(Model.PromoCode))
                            {
                                <p class="mb-1"><small class="text-muted">(Mã áp dụng: @Model.PromoCode)</small></p>
                            }
                            <h4 class="text-danger font-weight-bold mt-3">Tổng cộng: @Model.FinalAmount.ToString("N0") đ</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Cột phải: Thông tin giao hàng & Trạng thái -->
        <div class="col-xl-4 col-lg-5">
            <!-- Box 1: Cập nhật Trạng thái đơn hàng -->
            <div class="card shadow mb-4 border-bottom-warning">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-warning">Cập nhật trạng thái</h6>
                </div>
                <div class="card-body">
                    <form asp-action="UpdateStatus" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <div class="form-group mb-3">
                            <label class="font-weight-bold">Trạng thái hiện tại:</label>
                            <select name="status" class="form-control font-weight-bold">
                                <!option value="0" @(Model.OrderStatus == 0 ? "selected" : "")>Chờ duyệt</!option>
                                <!option value="1" @(Model.OrderStatus == 1 ? "selected" : "")>Đóng gói</!option>
                                <!option value="2" @(Model.OrderStatus == 2 ? "selected" : "")>Đang giao</!option>
                                <!option value="3" @(Model.OrderStatus == 3 ? "selected" : "")>Hoàn thành</!option>
                                <!option value="4" @(Model.OrderStatus == 4 ? "selected" : "")>Đã hủy</!option>
                            </select>
                        </div>
                        <button type="submit" class="btn btn-warning w-100" @(Model.OrderStatus == 3 || Model.OrderStatus == 4 ? "disabled" : "")>
                            <i class="fas fa-sync-alt"></i> Cập nhật ngay
                        </button>
                        @if(Model.OrderStatus == 3 || Model.OrderStatus == 4)
                        {
                            <p class="text-danger mt-3 small text-center"><i class="fas fa-info-circle"></i> Đơn hàng đã chốt, không thể thay đổi trạng thái.</p>
                        }
                    </form>
                </div>
            </div>

            <!-- Box 2: Thông tin Giao hàng -->
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-info">Thông tin giao hàng</h6>
                </div>
                <div class="card-body">
                    <p><strong><i class="fas fa-user mr-2 text-primary"></i>Người nhận:</strong> <br />@Model.ShippingFullName</p>
                    <p><strong><i class="fas fa-phone mr-2 text-success"></i>Số điện thoại:</strong> <br />@Model.ShippingPhoneNumber</p>
                    <p><strong><i class="fas fa-map-marker-alt mr-2 text-danger"></i>Địa chỉ:</strong> <br />@Model.ShippingAddress, @Model.ShippingDistrict, @Model.ShippingCity</p>
                    <hr />
                    <p><strong><i class="fas fa-wallet mr-2 text-warning"></i>Phương thức TT:</strong> <br />@Model.PaymentMethodName</p>
                </div>
            </div>
        </div>
    </div>
</div>
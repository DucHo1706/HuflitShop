@model IEnumerable<HuflitShopCore.DTOs.OrderDTO>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    bool pendingOnly = ViewBag.PendingOnly ?? false;
}

<style>
    .card-modern {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }
    .table-modern th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        background-color: #f8f9fc;
        border-bottom: 2px solid #e3e6f0;
    }
    .table-modern td {
        vertical-align: middle;
        font-size: 0.9rem;
    }
    .badge-paid {
        background-color: rgba(40, 167, 69, 0.1);
        color: #28a745;
        font-weight: 600;
        padding: 6px 12px;
        border-radius: 30px;
    }
    .badge-unpaid {
        background-color: rgba(220, 53, 69, 0.1);
        color: #dc3545;
        font-weight: 600;
        padding: 6px 12px;
        border-radius: 30px;
    }
    .badge-status {
        font-weight: 600;
        padding: 6px 12px;
        border-radius: 30px;
    }
    .btn-action {
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 0.8rem;
    }
</style>

<div class="container-fluid mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800 font-weight-bold">
                @if (pendingOnly)
                {
                    <span>Đơn hàng chờ duyệt</span>
                }
                else
                {
                    <span>Tất cả đơn hàng</span>
                }
            </h1>
            <p class="text-muted mb-0">Quản lý và cập nhật trạng thái đơn hàng của hệ thống.</p>
        </div>
        <div>
            @if (pendingOnly)
            {
                <a asp-action="Index" asp-route-pendingOnly="false" class="btn btn-secondary shadow-sm" style="border-radius: 20px;">
                    <i class="fas fa-list fa-sm mr-1"></i> Xem tất cả
                </a>
            }
            else
            {
                <a asp-action="Index" asp-route-pendingOnly="true" class="btn btn-warning text-dark shadow-sm font-weight-bold" style="border-radius: 20px;">
                    <i class="fas fa-clock fa-sm mr-1"></i> Lọc đơn chờ duyệt
                </a>
            }
        </div>
    </div>

    <div class="card card-modern mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-modern mb-0" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th class="pl-4">Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Thanh toán</th>
                            <th>Trạng thái</th>
                            <th class="text-center pr-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="pl-4 font-weight-bold text-primary"><span title="@item.Id">#@item.Id.Substring(0, 8).ToUpper()</span></td>
                                    <td>
                                        <div class="font-weight-bold text-dark">@item.CustomerName</div>
                                        <small class="text-muted">@item.ShippingFullName</small>
                                    </td>
                                    <td class="text-secondary">@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-dark font-weight-bold">@item.FinalAmount.ToString("N0") đ</td>
                                    <td>
                                        @if (item.PaymentStatus == 1)
                                        {
                                            <span class="badge-paid"><i class="fas fa-check-circle mr-1"></i> Đã TT</span>
                                        }
                                        else
                                        {
                                            <span class="badge-unpaid"><i class="fas fa-times-circle mr-1"></i> Chưa TT</span>
                                        }
                                    </td>
                                    <td>
                                        @switch (item.OrderStatus)
                                        {
                                            case 0:
                                                <span class="badge badge-status bg-warning text-dark"><i class="fas fa-hourglass-start mr-1"></i> @item.OrderStatusName</span>
                                                break;
                                            case 1:
                                                <span class="badge badge-status bg-info text-white"><i class="fas fa-box mr-1"></i> @item.OrderStatusName</span>
                                                break;
                                            case 2:
                                                <span class="badge badge-status bg-primary text-white"><i class="fas fa-shipping-fast mr-1"></i> @item.OrderStatusName</span>
                                                break;
                                            case 3:
                                                <span class="badge badge-status bg-success text-white"><i class="fas fa-check mr-1"></i> @item.OrderStatusName</span>
                                                break;
                                            case 4:
                                                <span class="badge badge-status bg-danger text-white"><i class="fas fa-times mr-1"></i> @item.OrderStatusName</span>
                                                break;
                                            default:
                                                <span class="badge badge-status bg-secondary text-white">@item.OrderStatusName</span>
                                                break;
                                        }
                                    </td>
                                    <td class="text-center pr-4">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-action text-white">
                                            <i class="fas fa-eye mr-1"></i> Chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="7" class="text-center py-5 text-muted">Không có đơn hàng nào để hiển thị.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
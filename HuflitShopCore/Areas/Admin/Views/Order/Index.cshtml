@model IEnumerable<HuflitShopCore.DTOs.OrderDTO>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    bool pendingOnly = ViewBag.PendingOnly ?? false;
}

<div class="container-fluid mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            @if (pendingOnly)
            {
                <span>Đơn hàng chờ duyệt</span>
            }
            else
            {
                <span>Tất cả đơn hàng</span>
            }
        </h1>
        <div>
            @if (pendingOnly)
            {
                <a asp-action="Index" asp-route-pendingOnly="false" class="btn btn-sm btn-secondary shadow-sm">
                    <i class="fas fa-list fa-sm text-white-50"></i> Xem tất cả
                </a>
            }
            else
            {
                <a asp-action="Index" asp-route-pendingOnly="true" class="btn btn-sm btn-warning shadow-sm">
                    <i class="fas fa-clock fa-sm text-white-50"></i> Lọc đơn chờ duyệt
                </a>
            }
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                    <thead class="thead-light">
                        <tr>
                            <th>Mã đơn</th>
                            <th>Khách hàng</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Thanh toán</th>
                            <th>Trạng thái</th>
                            <th class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td><span class="font-weight-bold" title="@item.Id">@item.Id.Substring(0, 8)...</span></td>
                                    <td>@item.CustomerName</td>
                                    <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-danger font-weight-bold">@item.FinalAmount.ToString("N0") đ</td>
                                    <td>
                                        @if (item.PaymentStatus == 1) { <span class="badge bg-success text-white">Đã TT</span> }
                                        else { <span class="badge bg-secondary text-white">Chưa TT</span> }
                                    </td>
                                    <td>
                                        @switch (item.OrderStatus)
                                        {
                                            case 0: <span class="badge bg-warning text-dark">@item.OrderStatusName</span>; break;
                                            case 1: <span class="badge bg-info text-white">@item.OrderStatusName</span>; break;
                                            case 2: <span class="badge bg-primary text-white">@item.OrderStatusName</span>; break;
                                            case 3: <span class="badge bg-success text-white">@item.OrderStatusName</span>; break;
                                            case 4: <span class="badge bg-danger text-white">@item.OrderStatusName</span>; break;
                                            default: <span class="badge bg-secondary text-white">@item.OrderStatusName</span>; break;
                                        }
                                    </td>
                                    <td class="text-center">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">
                                            <i class="fas fa-eye"></i> Chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="7" class="text-center">Không có đơn hàng nào.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
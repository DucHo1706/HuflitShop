@model IEnumerable<HuflitShopCore.DTOs.OrderDTO>

@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    bool pendingOnly = ViewBag.PendingOnly ?? false;
}

<style>
    .card-modern {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    }
    .table-modern th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        background-color: #f8f9fc;
        border-bottom: 2px solid #e3e6f0;
    }
    .table-modern td {
        vertical-align: middle;
        font-size: 0.9rem;
    }
    .badge-paid {
        background-color: rgba(40, 167, 69, 0.1);
        color: #28a745;
        font-weight: 600;
        padding: 6px 12px;
        border-radius: 30px;
    }
    .badge-unpaid {
        background-color: rgba(220, 53, 69, 0.1);
        color: #dc3545;
        font-weight: 600;
        padding: 6px 12px;
        border-radius: 30px;
    }
    .badge-status {
        font-weight: 600;
        padding: 6px 12px;
        border-radius: 30px;
    }
    .btn-action {
        border-radius: 20px;
        padding: 4px 12px;
        font-size: 0.8rem;
    }
</style>

<div class="container-fluid mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800 font-weight-bold">
                @if (pendingOnly)
                {
                    <span>Đơn hàng chờ duyệt</span>
                }
                else
                {
                    <span>Tất cả đơn hàng</span>
                }
            </h1>
            <p class="text-muted mb-0">Quản lý và cập nhật trạng thái đơn hàng của hệ thống.</p>
        </div>
        <div>
            @if (pendingOnly)
            {
                <a asp-action="Index" asp-route-pendingOnly="false" class="btn btn-secondary shadow-sm" style="border-radius: 20px;">
                    <i class="fas fa-list fa-sm mr-1"></i> Xem tất cả
                </a>
            }
            else
            {
                <a asp-action="Index" asp-route-pendingOnly="true" class="btn btn-warning text-dark shadow-sm font-weight-bold" style="border-radius: 20px;">
                    <i class="fas fa-clock fa-sm mr-1"></i> Lọc đơn chờ duyệt
                </a>
            }
        </div>
    </div>

    <!-- Advanced Filter Card -->
    <div class="card shadow mb-4" style="border-radius: 12px; border: none;">
        <div class="card-body p-3 bg-light" style="border-radius: 12px;">
            <div class="row">
                <div class="col-md-3 mb-2 mb-md-0">
                    <label class="font-weight-bold small text-muted">Trạng thái đơn hàng:</label>
                    <select id="filterStatus" class="form-control form-control-sm shadow-sm" style="border-radius: 8px;">
                        <option value="" selected="@(!pendingOnly ? "selected" : null)">-- Tất cả trạng thái --</option>
                        <option value="0" selected="@(pendingOnly ? "selected" : null)">Chờ duyệt</option>
                        <option value="1">Đóng gói</option>
                        <option value="2">Đang giao</option>
                        <option value="3">Hoàn thành</option>
                        <option value="4">Đã hủy</option>
                    </select>
                </div>
                <div class="col-md-3 mb-2 mb-md-0">
                    <label class="font-weight-bold small text-muted">Trạng thái thanh toán:</label>
                    <select id="filterPayment" class="form-control form-control-sm shadow-sm" style="border-radius: 8px;">
                        <option value="">-- Tất cả thanh toán --</option>
                        <option value="1">Đã thanh toán</option>
                        <option value="0">Chưa thanh toán</option>
                    </select>
                </div>
                <div class="col-md-3 mb-2 mb-md-0">
                    <label class="font-weight-bold small text-muted">Từ ngày:</label>
                    <input type="date" id="filterStartDate" class="form-control form-control-sm shadow-sm" style="border-radius: 8px;" />
                </div>
                <div class="col-md-3">
                    <label class="font-weight-bold small text-muted">Đến ngày:</label>
                    <input type="date" id="filterEndDate" class="form-control form-control-sm shadow-sm" style="border-radius: 8px;" />
                </div>
            </div>
        </div>
    </div>

    <div class="card card-modern mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-modern mb-0 no-datatable" id="dataTable" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th class="pl-4">Mã đơn</th>
                            <th>Khách hàng & Sản phẩm</th>
                            <th>Ngày đặt</th>
                            <th>Tổng tiền</th>
                            <th>Thanh toán</th>
                            <th>Trạng thái</th>
                            <th class="text-center pr-4">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr data-status="@item.OrderStatus" data-payment="@item.PaymentStatus" data-date="@item.OrderDate.ToString("yyyy-MM-dd")">
                                    <td class="pl-4 font-weight-bold text-primary"><span title="@item.Id">#@item.Id.Substring(0, 8).ToUpper()</span></td>
                                    <td>
                                        <div class="font-weight-bold text-dark">@item.CustomerName</div>
                                        <small class="text-muted d-block mb-1">Người nhận: @item.ShippingFullName</small>
                                        @if (item.OrderDetails != null && item.OrderDetails.Any())
                                        {
                                            <div class="mt-2 pt-2 border-top" style="font-size: 0.8rem; line-height: 1.4;">
                                                @foreach (var detail in item.OrderDetails)
                                                {
                                                    <div class="text-secondary mb-1">
                                                        <i class="fas fa-tshirt fa-xs text-muted mr-1"></i>
                                                        <span class="font-weight-bold text-primary">@detail.Quantity x</span> @detail.ProductNameSnapshot 
                                                        <span class="badge badge-light" style="font-size: 0.7rem; padding: 2px 5px;">@detail.ColorNameSnapshot / @detail.SizeNameSnapshot</span>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </td>
                                    <td class="text-secondary">@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-dark font-weight-bold">@item.FinalAmount.ToString("N0") đ</td>
                                    <td>
                                        @if (item.PaymentStatus == 1)
                                        {
                                            <span class="badge-paid"><i class="fas fa-check-circle mr-1"></i> Đã TT</span>
                                        }
                                        else
                                        {
                                            <span class="badge-unpaid"><i class="fas fa-times-circle mr-1"></i> Chưa TT</span>
                                        }
                                    </td>
                                    <td>
                                        @switch (item.OrderStatus)
                                        {
                                            case 0:
                                                <span class="badge badge-status bg-warning text-dark"><i class="fas fa-hourglass-start mr-1"></i> @item.OrderStatusName</span>
                                                break;
                                            case 1:
                                                <span class="badge badge-status bg-info text-white"><i class="fas fa-box mr-1"></i> @item.OrderStatusName</span>
                                                break;
                                            case 2:
                                                <span class="badge badge-status bg-primary text-white"><i class="fas fa-shipping-fast mr-1"></i> @item.OrderStatusName</span>
                                                break;
                                            case 3:
                                                <span class="badge badge-status bg-success text-white"><i class="fas fa-check mr-1"></i> @item.OrderStatusName</span>
                                                break;
                                            case 4:
                                                <span class="badge badge-status bg-danger text-white"><i class="fas fa-times mr-1"></i> @item.OrderStatusName</span>
                                                break;
                                            default:
                                                <span class="badge badge-status bg-secondary text-white">@item.OrderStatusName</span>
                                                break;
                                        }
                                    </td>
                                    <td class="text-center pr-4">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-action text-white">
                                            <i class="fas fa-eye mr-1"></i> Chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="7" class="text-center py-5 text-muted">Không có đơn hàng nào để hiển thị.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Initialize DataTable manually for custom sorting and language translation
            var table = $('#dataTable').DataTable({
                "order": [[2, "desc"]], // Sort by date descending
                "language": {
                    "search": "Tìm kiếm nhanh:",
                    "lengthMenu": "Hiển thị _MENU_ dòng",
                    "info": "Hiển thị từ _START_ đến _END_ trong tổng số _TOTAL_ đơn hàng",
                    "infoEmpty": "Không có dữ liệu",
                    "zeroRecords": "Không tìm thấy đơn hàng phù hợp",
                    "paginate": {
                        "next": "Sau",
                        "previous": "Trước"
                    }
                }
            });

            // Register DataTable custom search filter function
            $.fn.dataTable.ext.search.push(
                function(settings, data, dataIndex) {
                    if (settings.nTable.id !== 'dataTable') {
                        return true;
                    }

                    var row = $(table.row(dataIndex).node());
                    var orderStatus = row.attr('data-status');
                    var paymentStatus = row.attr('data-payment');
                    var orderDateStr = row.attr('data-date'); // "yyyy-MM-dd"

                    var filterStatus = $('#filterStatus').val();
                    var filterPayment = $('#filterPayment').val();
                    var filterStart = $('#filterStartDate').val(); // "yyyy-MM-dd"
                    var filterEnd = $('#filterEndDate').val(); // "yyyy-MM-dd"

                    // Order Status filter
                    if (filterStatus && filterStatus !== "" && orderStatus !== filterStatus) {
                        return false;
                    }

                    // Payment Status filter
                    if (filterPayment && filterPayment !== "" && paymentStatus !== filterPayment) {
                        return false;
                    }

                    // Date range filter
                    if (orderDateStr) {
                        if (filterStart && orderDateStr < filterStart) {
                            return false;
                        }
                        if (filterEnd && orderDateStr > filterEnd) {
                            return false;
                        }
                    }

                    return true;
                }
            );

            // Re-draw table when filters change
            $('#filterStatus, #filterPayment, #filterStartDate, #filterEndDate').on('change', function () {
                table.draw();
            });

            // Trigger initial filtering if some values are preselected
            if ($('#filterStatus').val() !== "") {
                table.draw();
            }
        });
    </script>
}
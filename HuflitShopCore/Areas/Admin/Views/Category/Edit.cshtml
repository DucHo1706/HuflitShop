@model HuflitShopCore.DTOs.CategoryDTO
@{
    ViewData["Title"] = "Chỉnh sửa danh mục";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <h2>Chỉnh sửa danh mục</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <!-- Bắt buộc phải có hidden Id để POST map đúng object -->
                <input type="hidden" asp-for="Id" />
                
                <div class="form-group mb-3">
                    <label asp-for="CategoryName" class="control-label fw-bold">Tên danh mục</label>
                    <input asp-for="CategoryName" class="form-control" />
                    <span asp-validation-for="CategoryName" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label asp-for="ParentId" class="control-label fw-bold">Thuộc danh mục cha (Tùy chọn)</label>
                    <select asp-for="ParentId" class="form-control" asp-items="ViewBag.ParentList">
                        <option value="">-- Chọn danh mục cha --</option>
                    </select>
                    <span asp-validation-for="ParentId" class="text-danger"></span>
                </div>
                
                <div class="form-group">
                    <button type="submit" class="btn btn-primary">Cập nhật thay đổi</button>
                    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
                </div>
            </form>
        </div>
    </div>
</div>
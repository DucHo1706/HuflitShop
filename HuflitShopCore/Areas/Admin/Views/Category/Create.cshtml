@model HuflitShopCore.DTOs.CategoryDTO
@{
    ViewData["Title"] = "Tạo danh mục mới";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<style>
    .admin-container {
        padding: 1.5rem 1rem;
        background-color: #f8fafc;
        min-height: calc(100vh - 60px);
    }

    .admin-page-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: 0;
        letter-spacing: -0.5px;
    }

    .admin-card {
        background: #ffffff;
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.03);
        border: 1px solid #e2e8f0;
        border-top: 4px solid #06b6d4;
        padding: 2rem;
        margin-top: 1.5rem;
    }

    .form-control {
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        padding: 0.75rem 1rem;
        font-size: 0.95rem;
        background-color: #f8fafc;
        transition: all 0.2s;
        color: #334155;
    }

        .form-control:focus {
            border-color: #06b6d4;
            background-color: #fff;
            box-shadow: 0 0 0 3px rgba(6,182,212,0.1);
            outline: none;
        }

    .control-label {
        font-weight: 700;
        color: #475569;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.6rem;
        display: block;
    }

    .btn-admin-primary {
        background: linear-gradient(135deg, #2563eb, #06b6d4);
        color: #ffffff;
        border: none;
        font-weight: 700;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        transition: all 0.3s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 100%;
        cursor: pointer;
        text-transform: uppercase;
        font-size: 0.9rem;
    }

        .btn-admin-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 10px rgba(37,99,235,0.2);
            color: white;
            text-decoration: none;
        }

    .btn-admin-secondary {
        background: #ffffff;
        border: 2px solid #cbd5e1;
        color: #475569;
        font-weight: 700;
        padding: 0.65rem 1.5rem;
        border-radius: 8px;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 100%;
        text-transform: uppercase;
        text-decoration: none;
        font-size: 0.9rem;
    }

        .btn-admin-secondary:hover {
            background: #f8fafc;
            color: #0f172a;
            border-color: #94a3b8;
            text-decoration: none;
        }
</style>

<div class="container-fluid admin-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="admin-page-title">Tạo danh mục mới</h1>
            <p class="text-muted small mb-0 mt-1">Thêm nhóm phân loại sản phẩm mới</p>
        </div>
        <a asp-action="Index" class="btn-admin-secondary" style="width: auto;">
            <i class="fas fa-arrow-left"></i> Quay lại
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <form asp-action="Create" method="post" class="admin-card">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded shadow-sm font-weight-bold border-0" style="background-color: #fee2e2; color: #dc2626;"></div>

                <div class="form-group mb-4">
                    <label asp-for="CategoryName" class="control-label">Tên danh mục</label>
                    <input asp-for="CategoryName" class="form-control" placeholder="Nhập tên danh mục..." />
                    <span asp-validation-for="CategoryName" class="text-danger small font-weight-bold mt-1 d-block"></span>
                </div>

                <div class="form-group mb-5">
                    <label asp-for="ParentId" class="control-label">Thuộc danh mục cha (Tùy chọn)</label>
                    <select asp-for="ParentId" class="form-control" asp-items="ViewBag.ParentList">
                        <option value="">-- Chọn danh mục cha --</option>
                    </select>
                    <span asp-validation-for="ParentId" class="text-danger small font-weight-bold mt-1 d-block"></span>
                </div>

                <div class="row">
                    <div class="col-6">
                        <a asp-action="Index" class="btn-admin-secondary">Hủy bỏ</a>
                    </div>
                    <div class="col-6">
                        <button type="submit" class="btn-admin-primary"><i class="fas fa-save"></i> Lưu danh mục</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
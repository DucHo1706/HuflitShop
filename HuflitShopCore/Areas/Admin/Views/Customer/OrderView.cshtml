@model IEnumerable<HuflitShopCore.DTOs.CustomerOrderDTO>
@{
    ViewData["Title"] = "Lịch sử mua hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">Lịch sử mua hàng của khách hàng</h1>
        <a asp-action="Index" class="btn btn-secondary btn-sm shadow-sm">
            <i class="fas fa-arrow-left fa-sm text-white-50"></i> Quay lại
        </a>
    </div>

    <table class="table table-bordered table-striped">
        <thead class="thead-dark">
            <tr>
                <th>Mã đơn hàng</th>
                <th>Ngày mua</th>
                <th>Phương thức thanh toán</th>
                <th>Giá trị đơn hàng</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@(item.OrderDate.HasValue ? item.OrderDate.Value.ToString("dd/MM/yyyy HH:mm") : "---")</td>
                        <td>@item.PaymentMethodName</td>
                        <td>@item.FinalAmount.ToString("N0") VNĐ</td>
                        <td>
                            @switch (item.OrderStatus)
                            {
                                case 0: <span class="badge bg-warning text-dark">Chờ duyệt</span> break;
                                case 1: <span class="badge bg-info text-white">Đóng gói</span> break;
                                case 2: <span class="badge bg-primary text-white">Đang giao</span> break;
                                case 3: <span class="badge bg-success text-white">Hoàn thành</span> break;
                                case 4: <span class="badge bg-danger text-white">Đã hủy</span> break;
                                default: <span class="badge bg-secondary text-white">Không xác định</span> break;
                            }
                        </td>
                        <td>
                            <a asp-controller="Order" asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white" title="Chi tiết đơn hàng">
                                <i class="fas fa-info-circle"></i> Xem
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center">Khách hàng này chưa có đơn hàng nào</td>
                </tr>
            }
        </tbody>
    </table>
</div>
